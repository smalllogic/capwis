<style>
  @keyframes cap-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes cap-marquee-rev {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  .reveal-up, .reveal-left, .reveal-right, .reveal-product {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .reveal-left  { transform: translateX(-36px); }
  .reveal-right { transform: translateX(36px); }

  .is-visible {
    opacity: 1 !important;
    transform: none !important;
  }
</style>

<script>
  function initHomeAnimations() {
    const els = document.querySelectorAll(".reveal-up, .reveal-left, .reveal-right, .reveal-product");
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("is-visible");
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.05 });

    els.forEach((el) => {
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight && rect.bottom > 0) {
        el.classList.add("is-visible");
      } else {
        obs.observe(el);
      }
    });
  }

  document.addEventListener("DOMContentLoaded", initHomeAnimations);
  document.addEventListener("turbo:load", initHomeAnimations);
</script>
