<style>
  @keyframes marquee-strip {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @keyframes marquee-strip-reverse {
    from { transform: translateX(-50%); }
    to { transform: translateX(0); }
  }

  .reveal-left, .reveal-right, .reveal-up, .reveal-stat,
  .reveal-hero, .reveal-process, .reveal-card {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal-left { transform: translateX(-32px); }
  .reveal-right { transform: translateX(32px); }

  .revealed {
    opacity: 1 !important;
    transform: none !important;
  }
</style>

<script>
  function initFactoryAnimations() {
    // Scroll reveal
    const revealEls = document.querySelectorAll(
      ".reveal-left, .reveal-right, .reveal-up, .reveal-stat, .reveal-hero, .reveal-process, .reveal-card"
    );
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05 });

    revealEls.forEach((el) => {
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight && rect.bottom > 0) {
        el.classList.add("revealed");
      } else {
        observer.observe(el);
      }
    });

    // Animated counters
    function animateCounter(el) {
      if (el.dataset.animated) return;
      el.dataset.animated = "1";
      const target = parseInt(el.dataset.target, 10);
      const step = target / (1800 / 16);
      let current = 0;
      const timer = setInterval(() => {
        current += step;
        if (current >= target) { current = target; clearInterval(timer); }
        el.textContent = target >= 1000000
          ? (current / 1000000).toFixed(1) + "M"
          : Math.floor(current).toLocaleString();
      }, 16);
    }

    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.querySelectorAll(".counter").forEach(animateCounter);
          counterObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    document.querySelectorAll(".reveal-stat").forEach(el => counterObserver.observe(el));
  }

  document.addEventListener("DOMContentLoaded", initFactoryAnimations);
  document.addEventListener("turbo:load", initFactoryAnimations);
</script>
