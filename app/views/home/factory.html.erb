<% content_for :title, "Our Factory - Capwis Hat Manufacturing in Qingdao, China" %>
<% content_for :meta_description, "Tour the Capwis factory in Qingdao, China. 20,000+ sqm facility, 500+ skilled workers, full in-house capabilities from fabric to finished hat. ISO-certified manufacturing with 25+ years experience." %>
<% content_for :meta_keywords, "hat factory China, Qingdao hat manufacturer, hat manufacturing facility, OEM hat factory, Capwis factory" %>

<div class="bg-slate-50 min-h-screen overflow-x-hidden">

  <!-- Hero Section -->
