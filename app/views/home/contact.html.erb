<style>
    @keyframes fall {
        0% { transform: translateY(-80px) rotate(var(--rs)); opacity:0; }
        8% { opacity: var(--op); }
        90% { opacity: calc(var(--op) * 0.7); }
        100% { transform: translateY(110vh) rotate(var(--re)); opacity:0; }
    }
    @keyframes gradientShift {
        0%,100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }
    @keyframes ping {
        75%,100% { transform:scale(2.2);opacity:0; }
    }
    @keyframes fadeUp {
        from { opacity:0; transform:translateY(16px); }
        to { opacity:1; transform:translateY(0); }
    }

    .hw {
        position: relative;
        overflow: hidden;
        padding: 3rem 2rem 2.8rem;
        text-align: center;
        background: linear-gradient(160deg, #fff8f2 0%, #fdf4ff 40%, #f0f9ff 100%);
    }
    .blob { position:absolute;border-radius:50%;filter:blur(90px);pointer-events:none;z-index:0; }
    .b1{width:360px;height:360px;top:-120px;left:-80px;background:rgba(249,115,22,0.13);}
    .b2{width:320px;height:320px;top:-80px;right:-60px;background:rgba(59,130,246,0.12);}
    .b3{width:300px;height:300px;bottom:-100px;left:30%;background:rgba(236,72,153,0.11);}
    .b4{width:220px;height:220px;bottom:0;right:5%;background:rgba(16,185,129,0.12);}

    .caps-layer { position:absolute;inset:0;pointer-events:none;overflow:hidden;z-index:1; }
    .cap { position:absolute;top:-80px;line-height:1; }

    .content { position:relative;z-index:3;max-width:560px;margin:0 auto; }

    .badge {
        display:inline-flex;align-items:center;gap:9px;
        padding:7px 18px;
        background:rgba(255,255,255,0.75);
        backdrop-filter:blur(10px);
        border:0.5px solid rgba(249,115,22,0.25);
        border-radius:999px;
        margin-bottom:1.2rem;
        box-shadow:0 2px 20px rgba(249,115,22,0.1);
        animation: fadeUp 0.6s ease both;
    }
    .dot-wrap{position:relative;width:9px;height:9px;flex-shrink:0;}
    .dot-ping{position:absolute;inset:0;border-radius:50%;background:#10b981;animation:ping 1.6s cubic-bezier(0,0,0.2,1) infinite;}
    .dot-core{position:relative;width:9px;height:9px;border-radius:50%;background:#10b981;}
    .badge-txt{font-size:10.5px;letter-spacing:0.22em;font-weight:700;text-transform:uppercase;color:#9a6c2a;}

    .title {
        margin:0 0 0.6rem;
        animation: fadeUp 0.6s 0.15s ease both;
    }
    .t1 {
        display:block;
        font-size: clamp(1.6rem, 5vw, 2.8rem);
        font-weight:900;
        letter-spacing:-0.03em;
        line-height:1.1;
        background: linear-gradient(100deg, #f97316 0%, #ec4899 35%, #3b82f6 65%, #10b981 100%);
        background-size: 250% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: fadeUp 0.6s 0.15s ease both, gradientShift 6s ease infinite;
    }
    .t2 {
        display:block;
        font-size: clamp(1.6rem, 5vw, 2.8rem);
        font-weight:900;
        letter-spacing:-0.03em;
        line-height:1.1;
        color:#1a1009;
        animation: fadeUp 0.6s 0.2s ease both;
    }

    .rule {
        display:flex;align-items:center;justify-content:center;gap:10px;
        margin:1rem 0;
        animation: fadeUp 0.6s 0.3s ease both;
    }
    .rl {
        flex:1;max-width:80px;height:1.5px;border-radius:999px;
        background:linear-gradient(90deg,transparent,#f97316);
    }
    .rr {
        flex:1;max-width:80px;height:1.5px;border-radius:999px;
        background:linear-gradient(90deg,#3b82f6,transparent);
    }
    .rdot {
        width:6px;height:6px;border-radius:50%;
        background:linear-gradient(135deg,#f97316,#ec4899);
    }

    .desc {
        font-size:0.92rem;
        line-height:1.9;
        color:#7c6a5a;
        margin:0;
        animation: fadeUp 0.6s 0.35s ease both;
    }
    .desc em {
        font-style:normal;
        font-weight:700;
        background:linear-gradient(90deg,#f97316,#ec4899);
        -webkit-background-clip:text;
        -webkit-text-fill-color:transparent;
        background-clip:text;
    }
    .sep { margin:0 6px;color:#d4b89a; }
</style>

<div class="hw">
  <div class="blob b1"></div>
  <div class="blob b2"></div>
  <div class="blob b3"></div>
  <div class="blob b4"></div>
  <div class="caps-layer" id="caps"></div>

  <div class="content">
    <div class="badge">
      <div class="dot-wrap"><span class="dot-ping"></span><span class="dot-core"></span></div>
      <span class="badge-txt">Usually Replies Within 4 Hour</span>
    </div>

    <h1 class="title">
      <span class="t1">Let's Talk</span>
      <span class="t2">About Your Project</span>
    </h1>

    <div class="rule">
      <div class="rl"></div>
      <div class="rdot"></div>
      <div class="rr"></div>
    </div>

    <p class="desc">
      <em>Custom Cap Manufacturing</em>
      <span class="sep">·</span>
      OEM &amp; ODM Projects


      <span class="sep">·</span>
All kinds of caps    </p>
  </div>
</div>

<script>
    const CAPS = ["🧢","👒","🤝","🎓","🧢","👒","🎩","🧢","👒","🧢"];
    const layer = document.getElementById('caps');
    for(let i=0;i<40;i++){
        const el = document.createElement('div');
        el.className = 'cap';
        el.textContent = CAPS[i % CAPS.length];
        const x = (Math.random()*98).toFixed(1);
        const dur = (7 + Math.random()*11).toFixed(2);
        const delay = -(Math.random()*parseFloat(dur));
        const size = (1.0 + Math.random()*1.6).toFixed(2);
        const op = (0.3 + Math.random()*0.45).toFixed(2);
        const rs = (Math.random()*30-15).toFixed(0)+'deg';
        const re = (180+Math.random()*360).toFixed(0)+'deg';
        el.style.cssText=`--rs:${rs};--re:${re};--op:${op};left:${x}%;font-size:${size}rem;opacity:0;animation:fall ${dur}s ${delay}s linear infinite;`;
        layer.appendChild(el);
    }
</script>


<div class="bg-white py-24">
  <div class="max-w-screen-xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16">
    <!-- Contact Form -->
    <div class="bg-slate-50 p-8 md:p-12 rounded-[2.5rem] border border-slate-100 shadow-2xl shadow-primary/5">
      <h2 class="text-2xl font-black text-slate-900 mb-8"><%= t('home.contact.send_message') %></h2>

      <%= form_with(model: @contact_message, url: contact_path, local: true, class: "space-y-6", x_data: "{ agreed: false, verified: false }", "@submit.prevent": "if(agreed && verified) $el.submit(); else if(!agreed) alert('#{t('home.contact.form.privacy_error')}'); else alert('#{t('home.contact.form.verification_failed')}')", "@turnstile-verified.window": "verified = true") do |f| %>
        <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
        <% if @contact_message.errors.any? %>
          <div class="p-4 bg-red-50 border border-red-100 rounded-xl text-red-800 text-sm">
            <ul class="list-disc pl-5">
              <% @contact_message.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= f.label :name, t('home.contact.form.name'), class: "block text-xs font-black text-slate-400 uppercase tracking-widest mb-2 ml-1" %>
            <%= f.text_field :name, required: true, class: "w-full px-6 py-4 bg-white border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary/10 focus:border-primary transition-all duration-300 font-medium text-slate-900 placeholder-slate-300 shadow-sm", placeholder: t('home.contact.form.name_placeholder') %>
          </div>
          <div>
            <%= f.label :email, t('home.contact.form.email'), class: "block text-xs font-black text-slate-400 uppercase tracking-widest mb-2 ml-1" %>
            <%= f.email_field :email, required: true, class: "w-full px-6 py-4 bg-white border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary/10 focus:border-primary transition-all duration-300 font-medium text-slate-900 placeholder-slate-300 shadow-sm", placeholder: t('home.contact.form.email_placeholder') %>
          </div>
        </div>

        <div>
          <%= f.label :subject, t('home.contact.form.subject'), class: "block text-xs font-black text-slate-400 uppercase tracking-widest mb-2 ml-1" %>
          <%= f.text_field :subject, required: true, class: "w-full px-6 py-4 bg-white border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary/10 focus:border-primary transition-all duration-300 font-medium text-slate-900 placeholder-slate-300 shadow-sm", placeholder: t('home.contact.form.subject_placeholder') %>
        </div>

        <div>
          <%= f.label :message, t('home.contact.form.message'), class: "block text-xs font-black text-slate-400 uppercase tracking-widest mb-2 ml-1" %>
          <%= f.text_area :message, required: true, rows: 6, class: "w-full px-6 py-4 bg-white border border-slate-200 rounded-2xl focus:ring-4 focus:ring-primary/10 focus:border-primary transition-all duration-300 font-medium text-slate-900 placeholder-slate-300 shadow-sm resize-none", placeholder: t('home.contact.form.message_placeholder') %>
        </div>

        <!-- Cloudflare Turnstile Verification -->
        <div class="mt-8 pt-8 border-t border-slate-200/60">
          <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex flex-col items-center">
            <div class="cf-turnstile" data-sitekey="<%= ENV.fetch('CLOUDFLARE_TURNSTILE_SITE_KEY', '0x4AAAAAAA-7vO1W679X6iI6') %>" data-callback="onTurnstileSuccess" data-theme="light"></div>
            <p class="mt-3 text-xs font-bold text-slate-400 uppercase tracking-widest flex items-center">
              <svg class="w-3.5 h-3.5 mr-2 text-primary" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              Security Verification Required
            </p>
          </div>
        </div>

        <script>
          function onTurnstileSuccess(token) {
            window.dispatchEvent(new CustomEvent('turnstile-verified', { detail: { token: token } }));
          }
        </script>

        <div class="flex items-start space-x-3 pt-6">
          <div class="flex items-center h-5">
            <%= check_box_tag :privacy_agreement, "1", false, x_model: "agreed", class: "w-5 h-5 text-primary border-slate-300 rounded focus:ring-primary cursor-pointer" %>
          </div>
          <div class="text-sm">
            <label for="privacy_agreement" class="font-medium text-slate-600">
              <%= t('home.contact.form.privacy_policy_agree') %>
              <a href="<%= privacy_path %>" target="_blank" class="text-primary hover:text-primary/80 font-bold underline underline-offset-4">
                <%= t('home.contact.form.privacy_policy_link') %>
              </a>
            </label>
          </div>
        </div>

        <%= f.submit t('home.contact.form.submit'), 
            class: "w-full py-5 bg-primary hover:bg-primary/90 active:scale-[0.98] text-white rounded-[2rem] font-black text-sm tracking-widest uppercase transition-all shadow-2xl shadow-primary/40 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed mt-6", 
            ":disabled": "!agreed || !verified" %>
      <% end %>
    </div>

    <div class="flex flex-col justify-center">
      <div class="space-y-8">
        <div class="relative pl-8 border-l-4 border-primary">
          <h2 class="text-4xl font-black text-slate-900 mb-6 tracking-tight leading-tight"><%= t('home.contact.address_title') %></h2>
          <p class="text-slate-500 font-medium text-lg leading-relaxed max-w-md">
            <%= (@site_config.address.presence || t('contact_info.address')).gsub(', ', '<br/>').html_safe %>
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="group p-8 bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 hover:shadow-2xl hover:shadow-primary/5 transition-all duration-500">
            <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-primary transition-all duration-500">
              <svg class="w-7 h-7 text-primary group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
            <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-2"><%= t('home.contact.phone_title') %></h3>
            <p class="text-xl font-black text-slate-900 tracking-tight">
              <% phone = @site_config.phone.presence || t('contact_info.phone') %>
              <%= link_to phone, "tel:#{phone}", class: "hover:text-primary transition-colors" %>
            </p>
          </div>

          <div class="group p-8 bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 hover:shadow-2xl hover:shadow-secondary/5 transition-all duration-500">
            <div class="w-14 h-14 bg-secondary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-secondary transition-all duration-500">
              <svg class="w-7 h-7 text-secondary group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-2"><%= t('home.contact.email_title') %></h3>
            <p class="text-lg font-black text-slate-900 tracking-tight break-all">
              <% email = @site_config.email.presence || t('contact_info.email') %>
              <%= link_to email, "mailto:#{email}", class: "hover:text-secondary transition-colors" %>
            </p>
          </div>
        </div>

        <div class="group p-10 bg-slate-900 rounded-[3rem] text-white relative overflow-hidden shadow-2xl">
          <div class="absolute -bottom-10 -right-10 w-48 h-48 bg-primary rounded-full blur-[80px] opacity-20 group-hover:opacity-40 transition-opacity duration-700"></div>
          <div class="absolute -top-10 -left-10 w-32 h-32 bg-secondary rounded-full blur-[60px] opacity-10 group-hover:opacity-30 transition-opacity duration-700"></div>
          
          <div class="relative z-10">
            <h3 class="text-2xl font-black mb-4"><%= t('home.contact.support_card_title') %></h3>
            <p class="text-slate-400 text-base leading-relaxed mb-6">
              Professional support and consulting services for your brand development. We are here to help you succeed.
            </p>
            <div class="flex items-center space-x-4">
              <div class="flex -space-x-2">
                <div class="w-10 h-10 rounded-full border-2 border-slate-900 bg-slate-800 flex items-center justify-center text-[10px] font-bold">JD</div>
                <div class="w-10 h-10 rounded-full border-2 border-slate-900 bg-slate-700 flex items-center justify-center text-[10px] font-bold">AS</div>
                <div class="w-10 h-10 rounded-full border-2 border-slate-900 bg-primary flex items-center justify-center text-[10px] font-bold">+5</div>
              </div>
              <span class="text-xs font-bold text-slate-500 tracking-wider uppercase">Active Support Team</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
