<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-800">About Us 轮播管理</h1>
  <%= link_to '添加新轮播', new_admin_about_carousel_path, class: "bg-primary text-white px-4 py-2 rounded-lg hover:bg-primary-dark transition shadow-sm" %>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">图片</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">标题</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">排序</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">状态</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">操作</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @about_carousels.each do |carousel| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="h-16 w-16 rounded overflow-hidden bg-gray-100">
              <% if carousel.image.attached? %>
                <%= image_tag carousel.image.variant(:thumb), class: "h-full w-full object-cover" %>
              <% else %>
                <div class="h-full w-full flex items-center justify-center text-gray-400">
                  <i class="fas fa-image"></i>
                </div>
              <% end %>
            </div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="text-sm font-bold text-gray-900"><%= carousel.title %></div>
            <div class="text-xs text-gray-500 truncate max-w-xs"><%= carousel.description %></div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= carousel.position %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <% if carousel.active %>
              <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">已激活</span>
            <% else %>
              <span class="px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">未激活</span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
            <%= link_to '编辑', edit_admin_about_carousel_path(carousel), class: "text-blue-600 hover:text-blue-900" %>
            <%= link_to '删除', admin_about_carousel_path(carousel), data: { turbo_method: :delete, turbo_confirm: '确定要删除吗？' }, class: "text-red-600 hover:text-red-900" %>
          </td>
        </tr>
      <% end %>
      <% if @about_carousels.empty? %>
        <tr>
          <td colspan="5" class="px-6 py-10 text-center text-gray-500">
            暂无轮播数据，请点击右上角添加。
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
