<%= form_with(model: [:admin, home_product], class: "space-y-6") do |f| %>
  <% if home_product.errors.any? %>
    <div class="bg-red-50 text-red-700 p-4 rounded-lg text-sm">
      <h2 class="font-bold mb-2"><%= pluralize(home_product.errors.count, "error") %> prohibited this product from being saved:</h2>
      <ul class="list-disc list-inside">
        <% home_product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="space-y-2">
      <%= f.label :title, "标题 (鼠标悬停显示)", class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :title, class: "w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary shadow-sm" %>
    </div>

    <div class="space-y-2">
      <%= f.label :link, "点击跳转链接 (可选)", class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :link, class: "w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary shadow-sm", placeholder: "https://..." %>
    </div>

    <div class="space-y-2">
      <%= f.label :row, "所属行位置", class: "block text-sm font-medium text-slate-700" %>
      <%= f.select :row, HomeProduct.row_options, {}, class: "w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary shadow-sm" %>
      <p class="text-xs text-slate-500 italic">第一行为大图(56x64)，第二行为小图(44x52)</p>
    </div>

    <div class="space-y-2">
      <%= f.label :position, "显示排序 (越小越靠前)", class: "block text-sm font-medium text-slate-700" %>
      <%= f.number_field :position, class: "w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary shadow-sm" %>
    </div>

    <div class="space-y-2">
      <%= f.label :image, "上传图片", class: "block text-sm font-medium text-slate-700" %>
      <%= f.file_field :image, class: "w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20" %>
      <% if home_product.image.attached? %>
        <div class="mt-2">
          <%= image_tag home_product.image.variant(:thumb), class: "h-20 w-20 object-cover rounded border" %>
        </div>
      <% end %>
    </div>

    <div class="flex items-center space-x-2 pt-8">
      <%= f.check_box :active, class: "rounded border-slate-300 text-primary focus:ring-primary h-4 w-4" %>
      <%= f.label :active, "在首页公开显示", class: "text-sm font-medium text-slate-700" %>
    </div>
  </div>

  <div class="pt-6 border-t border-slate-200 flex justify-end space-x-3">
    <%= link_to "取消", admin_home_products_path, class: "px-4 py-2 border border-slate-300 rounded-lg text-slate-700 hover:bg-slate-50 transition-colors" %>
    <%= f.submit "保存设置", class: "px-4 py-2 bg-primary hover:bg-primary/90 text-white rounded-lg cursor-pointer transition-colors shadow-sm" %>
  </div>
<% end %>
