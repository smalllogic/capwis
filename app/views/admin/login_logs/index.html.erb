<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-slate-800">登录日志</h1>
  <div class="flex items-center gap-4">
    <%= button_to "清理7天前日志", clear_admin_login_logs_path, 
                  method: :delete, 
                  class: "px-4 py-2 bg-red-50 text-red-600 hover:bg-red-100 rounded-lg text-sm font-medium transition-colors",
                  data: { turbo_confirm: "确定要清理7天前的登录日志吗？" } %>
    <div class="text-sm text-slate-500">
      仅大管理员可见
    </div>
  </div>
</div>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-slate-50 border-b border-slate-200">
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">用户</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">登录时间</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">IP 地址</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">地点</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">设备</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        <% if @login_logs.any? %>
          <% @login_logs.each do |log| %>
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-6 py-4">
                <div class="text-sm font-medium text-slate-900"><%= log.user&.email %></div>
                <div class="text-xs text-slate-500">ID: <%= log.user_id %></div>
              </td>
              <td class="px-6 py-4 text-sm text-slate-600">
                <%= log.login_at&.strftime("%Y-%m-%d %H:%M:%S") %>
              </td>
              <td class="px-6 py-4 text-sm text-slate-600 font-mono">
                <%= log.ip_address %>
              </td>
              <td class="px-6 py-4 text-sm text-slate-600">
                <% if log.country.present? %>
                  <%= [log.country, log.province, log.city].compact.join(" - ") %>
                <% else %>
                  <span class="text-slate-400 italic text-xs">解析中...</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-slate-500">
                <%= log.device_info %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="px-6 py-10 text-center text-slate-500">
              暂无登录日志。
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% if @login_logs.respond_to?(:total_pages) %>
    <div class="px-6 py-4 border-t border-slate-200">
      <%= paginate @login_logs %>
    </div>
  <% end %>
</div>
