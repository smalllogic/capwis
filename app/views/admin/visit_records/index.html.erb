<% content_for :admin_title, "数据统计 - 访客记录" %>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <div class="p-6 border-b border-slate-200 flex justify-between items-center bg-slate-50">
    <h3 class="font-bold text-slate-800 flex items-center">
      <svg class="w-5 h-5 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2"></path>
      </svg>
      访客访问记录
    </h3>
    <div class="flex items-center space-x-4">
      <span class="text-xs bg-blue-100 text-blue-700 px-3 py-1 rounded-full font-medium">今日 24h: <%= @today_count %></span>
      <span class="text-xs bg-slate-100 text-slate-700 px-3 py-1 rounded-full font-medium">累计总量: <%= @total_count %></span>
      <% if @records_older_than_7_days > 0 %>
        <span class="text-xs bg-orange-100 text-orange-700 px-3 py-1 rounded-full font-medium">7天前: <%= @records_older_than_7_days %></span>
      <% end %>
      <%= button_to clean_admin_visit_records_path, 
                    method: :delete, 
                    params: { days: 7 },
                    data: { confirm: "确定要清理7天以前的所有访客记录吗？此操作不可恢复！" },
                    class: "text-xs bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded-full font-medium cursor-pointer transition-colors" do %>
        🗑️ 清理7天前数据
      <% end %>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-slate-50 border-b border-slate-200">
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">访问时间</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">访问路径</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">IP 地址</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">设备</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">地理位置</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">国家/省份/城市/区域</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        <% if @visit_records.any? %>
          <% @visit_records.each do |record| %>
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-6 py-4 text-sm text-slate-600 whitespace-nowrap">
                <%= record.visit_time&.strftime("%Y-%m-%d %H:%M:%S") || "未知" %>
              </td>
              <td class="px-6 py-4 text-sm text-blue-600 font-mono break-all" style="max-width: 200px;">
                <%= record.path %>
              </td>
              <td class="px-6 py-4 text-sm font-medium text-slate-900">
                <%= record.ip %>
              </td>
              <td class="px-6 py-4 text-sm text-slate-600">
                <span class="px-2 py-1 bg-slate-100 rounded text-xs text-slate-600" title="<%= record.user_agent %>">
                  <%= record.device_info %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-slate-600">
                <%= record.address.presence || "解析中/未知" %>
              </td>
              <td class="px-6 py-4 text-sm text-slate-600">
                <div class="flex flex-wrap gap-1">
                  <% if record.country.present? %><span class="bg-blue-50 text-blue-700 px-2 py-0.5 rounded text-xs"><%= record.country %></span><% end %>
                  <% if record.state.present? %><span class="bg-green-50 text-green-700 px-2 py-0.5 rounded text-xs"><%= record.state %></span><% end %>
                  <% if record.city.present? %><span class="bg-orange-50 text-orange-700 px-2 py-0.5 rounded text-xs"><%= record.city %></span><% end %>
                  <% if record.district.present? %><span class="bg-purple-50 text-purple-700 px-2 py-0.5 rounded text-xs"><%= record.district %></span><% end %>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="px-6 py-10 text-center text-slate-500">
              暂无访客记录
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @visit_records.total_pages > 1 %>
    <div class="px-6 py-4 border-t border-slate-200 bg-slate-50">
      <%= paginate @visit_records %>
    </div>
  <% end %>
</div>
