<div class="max-w-4xl bg-white p-8 rounded-xl border border-slate-200 shadow-sm">
  <%= form_with(model: [:admin, @post], local: true) do |f| %>
    <% if @post.errors.any? %>
      <div class="mb-6 p-4 bg-red-50 border border-red-100 rounded-lg text-sm text-red-800">
        <ul class="list-disc pl-5">
          <% @post.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-6">
      <div>
        <%= f.label :title, "文章标题", class: "block text-sm font-semibold text-slate-700 mb-2" %>
        <%= f.text_field :title, class: "w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-slate-900", placeholder: "输入文章标题..." %>
      </div>

      <div>
        <%= f.label :summary, "简介", class: "block text-sm font-semibold text-slate-700 mb-2" %>
        <%= f.text_area :summary, rows: 3, class: "w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-slate-900 resize-none", placeholder: "一句话介绍这篇文章..." %>
      </div>

      <div>
        <%= f.label :cover_image, "封面图片", class: "block text-sm font-semibold text-slate-700 mb-2" %>
        <% if @post.cover_image.attached? %>
          <div class="mb-3">
            <%= image_tag @post.cover_image, class: "h-32 w-auto rounded-lg object-cover border border-slate-200" %>
          </div>
        <% end %>
        <%= f.file_field :cover_image, accept: "image/*", class: "block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 cursor-pointer" %>
      </div>

      <div>
        <%= f.label :content, "正文内容", class: "block text-sm font-semibold text-slate-700 mb-2" %>
        <div class="border border-slate-300 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-blue-500 focus-within:border-blue-500">
          <%= f.rich_text_area :content, class: "min-h-[400px]" %>
        </div>
      </div>

      <div>
        <%= f.label :status, "状态", class: "block text-sm font-semibold text-slate-700 mb-2" %>
        <%= f.select :status, [["草稿", "draft"], ["已发布", "published"]],
              {},
              class: "w-48 px-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-slate-900" %>
      </div>

      <div class="flex items-center gap-4 pt-4 border-t border-slate-100">
        <%= f.submit @post.new_record? ? "创建文章" : "保存修改",
              class: "px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-semibold transition-colors cursor-pointer" %>
        <%= link_to "取消", admin_posts_path, class: "px-6 py-2.5 border border-slate-300 text-slate-600 hover:bg-slate-50 rounded-lg text-sm font-semibold transition-colors" %>
      </div>
    </div>
  <% end %>
</div>
