<% content_for :title, "Capwis - Custom Hat Manufacturer | Baseball Caps, Trucker Hats & More" %>
<% content_for :meta_description, "Capwis is a professional custom hat manufacturer in Qingdao, China with 20+ years of experience. OEM & ODM baseball caps, trucker hats, bucket hats, beanies and more. Factory-direct pricing." %>
<% content_for :meta_keywords, "custom hat manufacturer, baseball cap OEM, trucker hat manufacturer, bucket hat, beanie cap, Qingdao hat factory, Capwis, hat ODM China" %>

<%# ============================================================
    Hero Section — Rebuilt Responsive Slideshow
    ============================================================ %>
<section
  class="relative -mt-20 w-full overflow-hidden"
  style="height: 100svh; min-height: 600px;"
  data-controller="slideshow"
  aria-label="Hero Slideshow"
>

  <%# ── 1. Background Slides ── %>
  <div class="absolute inset-0 z-0">
    <% [1, 2, 3].each_with_index do |n, idx| %>
      <div
        class="absolute inset-0 transition-opacity duration-1000 ease-in-out opacity-0"
        data-slideshow-target="slide"
      >
        <%= image_tag "banner#{n}.jpg",
                      class: "w-full h-full object-cover object-center scale-105 transition-transform duration-[5000ms]",
                      alt: "",
                      role: "presentation",
                      loading: idx == 0 ? "eager" : "lazy" %>
      </div>
    <% end %>
  </div>

  <%# ── 2. Overlay Gradients (Improved Contrast) ── %>
  <div class="absolute inset-0 z-10 pointer-events-none">
    <%# Bottom dark gradient for text readability %>
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
    <%# Left side gradient for desktop text focus %>
    <div class="absolute inset-0 hidden lg:block bg-gradient-to-r from-black/40 via-transparent to-transparent"></div>
  </div>

  <%# ── 3. Content ── %>
  <div class="absolute inset-0 z-20 flex flex-col justify-end lg:justify-center">
    <div class="w-full max-w-screen-xl mx-auto px-6 sm:px-12 lg:px-20 pb-16 lg:pb-0">
      
      <% [1, 2, 3].each_with_index do |i, idx| %>
        <div
          class="absolute bottom-16 lg:bottom-auto lg:top-1/2 lg:-translate-y-1/2 
                 max-w-2xl opacity-0 translate-y-8 pointer-events-none
                 transition-all duration-1000 ease-out"
          data-slideshow-target="content"
        >
          <%# Tagline %>
          <div class="inline-flex items-center gap-2 mb-4">
            <span class="w-8 h-[2px] bg-primary rounded-full"></span>
            <span class="text-white/90 text-[10px] sm:text-xs font-black tracking-[0.3em] uppercase">
              <%= t("home.index.hero_slides.slide#{i}.title1") %>
            </span>
          </div>

          <%# Main Title %>
          <h1 class="font-black text-white leading-[1.1] mb-6 drop-shadow-2xl"
              style="font-size: clamp(2.25rem, 8vw, 5rem);">
            <%= t("home.index.hero_slides.slide#{i}.title1") %><br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-white to-primary bg-[length:200%_auto] animate-gradient-x">
              <%= t("home.index.hero_slides.slide#{i}.title2") %>
            </span>
          </h1>

          <%# Description %>
          <p class="text-white/70 text-sm sm:text-base lg:text-lg max-w-md mb-8 leading-relaxed font-medium">
            <%= t("home.index.hero_slides.slide#{i}.desc") %>
          </p>

          <%# Actions %>
          <div class="flex flex-wrap gap-4 mt-auto">
            <%= link_to all_products_path,
                        class: "group relative overflow-hidden px-6 py-3.5 sm:px-8 sm:py-4 bg-primary text-white font-black text-[10px] sm:text-xs tracking-widest uppercase rounded-full shadow-2xl shadow-primary/30 transition-all hover:-translate-y-1 active:scale-95 flex items-center gap-2" do %>
              <%= t('home.index.explore_products') %>
              <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            <% end %>

            <%= link_to contact_path,
                        class: "px-6 py-3.5 sm:px-8 sm:py-4 bg-white/10 hover:bg-white/20 text-white font-black text-[10px] sm:text-xs tracking-widest uppercase rounded-full border border-white/30 backdrop-blur-md transition-all hover:-translate-y-1 active:scale-95" do %>
              <%= t('home.index.contact_us') %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── 4. Controls (Bottom Right) ── %>
  <div class="absolute bottom-8 right-6 lg:right-20 z-30 flex items-end gap-6">
    <%# Counter %>
    <div class="hidden sm:block text-white/50 font-mono text-sm tracking-tighter">
      <span class="text-white text-2xl font-black" data-slideshow-target="counter">01</span> / 03
    </div>

    <%# Indicators %>
    <div class="flex items-center gap-3">
      <% 3.times do |n| %>
        <button
          type="button"
          class="group relative h-10 w-1 flex items-center justify-center"
          data-action="click->slideshow#goTo"
          data-index="<%= n %>"
          aria-label="Go to slide <%= n + 1 %>"
        >
          <span class="block w-full h-full bg-white/20 rounded-full transition-all duration-500 group-hover:bg-white/40"
                data-slideshow-target="indicator"></span>
        </button>
      <% end %>
    </div>

    <%# Arrows %>
    <div class="flex gap-2">
      <button data-action="click->slideshow#prev" class="w-12 h-12 flex items-center justify-center rounded-full border border-white/20 text-white hover:bg-white/10 transition-all active:scale-90">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"/></svg>
      </button>
      <button data-action="click->slideshow#next" class="w-12 h-12 flex items-center justify-center rounded-full border border-white/20 text-white hover:bg-white/10 transition-all active:scale-90">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>

</section>

<!-- ===== CAP PRODUCT MARQUEE ===== -->
<div class="bg-slate-900 py-8 overflow-hidden">
  <div class="text-center mb-6">
    <span class="text-xs font-black text-slate-500 uppercase tracking-widest">Our Products</span>
  </div>
  <!-- Forward strip -->
  <div class="overflow-hidden mb-4">
    <div class="flex gap-5 w-max" style="animation: cap-marquee 32s linear infinite;">
      <% 2.times do %>
        <% [["cap1.webp","Baseball Cap"],["cap2.webp","Trucker Hat"],["cap3.jpg","Bucket Hat"],["cap4.webp","Flat Brim"],["cap5.webp","Wide Brim"]].each do |img, label| %>
          <div class="relative flex-shrink-0 w-56 h-64 rounded-2xl overflow-hidden group cursor-pointer">
            <%= image_tag img, class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" %>
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
              <span class="text-white font-bold text-sm tracking-wide"><%= label %></span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
  <!-- Reverse strip -->
  <div class="overflow-hidden">
    <div class="flex gap-5 w-max" style="animation: cap-marquee-rev 38s linear infinite;">
      <% 2.times do %>
        <% [["cap5.webp","Visor Hat"],["cap4.webp","Sports Cap"],["cap3.jpg","Sun Hat"],["cap2.webp","Mesh Cap"],["cap1.webp","Custom Cap"]].each do |img, label| %>
          <div class="relative flex-shrink-0 w-44 h-52 rounded-2xl overflow-hidden group cursor-pointer">
            <%= image_tag img, class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" %>
            <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-3">
              <span class="text-white font-bold text-xs tracking-wide"><%= label %></span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<!-- ===== FEATURED PRODUCTS GRID ===== -->
<div class="bg-white py-20 overflow-hidden">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="text-center mb-14 reveal-up">
      <p class="text-primary font-semibold tracking-widest uppercase text-xs mb-3">Crafted with Precision</p>
      <h2 class="text-4xl md:text-5xl font-black text-slate-900">Featured Products</h2>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4">
      <% if @featured_categories.any? %>
        <% @featured_categories.each_with_index do |category, i| %>
          <%= link_to category_path(category), 
                      class: "reveal-product group relative rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 cursor-pointer", 
                      style: "transition-delay: #{i * 80}ms" do %>
            <div class="aspect-[3/4] overflow-hidden bg-white">
              <% if category.image.attached? %>
                <%= image_tag category.image.variant(:featured), class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" %>
              <% else %>
                <div class="w-full h-full bg-slate-100 flex items-center justify-center text-slate-300 italic text-xs">No Image</div>
              <% end %>
            </div>
            <div class="absolute top-3 left-3">
              <span class="bg-primary text-white text-[10px] font-black uppercase tracking-widest px-2.5 py-1 rounded-full">Featured</span>
            </div>
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent px-5 pb-6 pt-16">
              <p class="text-white font-black text-xl leading-tight drop-shadow-lg"><%= category.name %></p>
              <p class="text-white/75 text-xs font-bold mt-1 uppercase tracking-widest">Custom · OEM · ODM</p>
            </div>
          <% end %>
        <% end %>
      <% else %>
        <% [
          { img: "product_baseball_cap.png",    name: "Baseball Cap",           tag: "Best Seller", color: "primary",   fit: "cover" },
          { img: "product_bucket_cap.png",      name: "Bucket Cap",             tag: "Trending",    color: "secondary", fit: "contain" },
          { img: "product_flat_bill_cap.png",   name: "Flat Bill Cap",          tag: "Custom",      color: "accent",    fit: "contain" },
          { img: "product_kids_cap.png",        name: "Kids Cap",               tag: "Cute",        color: "primary",   fit: "cover" },
          { img: "product_knit_beanie_cap.png", name: "Knit Beanie Cap",        tag: "Winter",      color: "secondary", fit: "cover" },
          { img: "product_quick_dry_cap.png",   name: "Quick Dry Baseball Cap", tag: "Sport",       color: "accent",    fit: "cover" }
        ].each_with_index do |cap, i| %>
          <div class="reveal-product group relative rounded-3xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 cursor-pointer" style="transition-delay: <%= i * 80 %>ms">
            <div class="aspect-[3/4] overflow-hidden bg-white">
              <%= image_tag cap[:img], class: "w-full h-full #{cap[:fit] == 'contain' ? 'object-contain p-4' : 'object-cover'} group-hover:scale-105 transition-transform duration-700" %>
            </div>
