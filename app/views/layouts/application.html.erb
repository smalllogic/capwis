<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <title><%= content_for(:title) || "Sinower" %></title>
    <meta name="description" content="<%= content_for(:meta_description) || "Sinower provides high-quality commercial refrigeration, cooking equipment, and stainless steel solutions for your business." %>">
    <meta name="keywords" content="<%= content_for(:meta_keywords) || "commercial refrigeration, cooking equipment, stainless steel, Sinower, kitchen solutions" %>">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%= favicon_link_tag "title.png" %>
    <%= favicon_link_tag "title.png", rel: "apple-touch-icon" %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style> [x-cloak] { display: none !important; } </style>
  </head>

  <body class="flex flex-col min-h-screen bg-white">
    <%= render "layouts/navbar" %>
    
    <main class="flex-grow pt-20">
      <% if notice %>
        <div class="max-w-screen-xl mx-auto px-5 mt-4">
          <p class="p-4 text-sm text-blue-800 rounded-lg bg-blue-50 border border-blue-100" role="alert"><%= notice %></p>
        </div>
      <% end %>
      <% if alert %>
        <div class="max-w-screen-xl mx-auto px-5 mt-4">
          <p class="p-4 text-sm text-red-800 rounded-lg bg-red-50 border border-red-100" role="alert"><%= alert %></p>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <%= render "layouts/footer" %>
    <%= render "shared/privacy_modal" %>
    <%= render "shared/cookie_banner" %>
  </body>
</html>
