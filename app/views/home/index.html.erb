            <span class="block text-slate-900 mb-2"><%= t("home.index.hero_slides.slide#{i}.title1") %></span>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-secondary to-accent animate-gradient-x"><%= t("home.index.hero_slides.slide#{i}.title2") %></span>
