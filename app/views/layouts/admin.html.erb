<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Lincaps Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 font-sans antialiased text-slate-900">
    <div class="flex min-h-screen">
      <%# Sidebar %>
      <%= render "admin/shared/sidebar" %>

      <%# Main Content Area %>
      <div class="flex-grow flex flex-col min-w-0">
        <%# Admin Navbar %>
        <header class="bg-white border-b border-slate-200 sticky top-0 z-20">
          <div class="px-8 py-4 flex items-center justify-between">
            <h1 class="text-xl font-semibold text-slate-800"><%= content_for(:admin_title) || "控制面板" %></h1>
            
            <div class="flex items-center space-x-6">
              <span class="text-sm text-slate-500">管理员: <%= current_user.email %></span>
              <%= link_to "修改密码", edit_admin_profile_path, class: "text-sm font-medium text-slate-600 hover:text-primary transition-colors" %>
              <%= button_to "退出登录", destroy_user_session_path, method: :delete, class: "text-sm font-medium text-red-600 hover:text-red-800 transition-colors" %>
            </div>
          </div>
        </header>

        <%# Page Content %>
        <main class="p-8">
          <% if notice %>
            <div class="p-4 mb-6 text-sm text-primary rounded-lg bg-primary/5 border border-primary/10" role="alert">
              <%= notice %>
            </div>
          <% end %>
          <% if alert %>
            <div class="p-4 mb-6 text-sm text-accent rounded-lg bg-accent/5 border border-accent/10" role="alert">
              <%= alert %>
            </div>
          <% end %>

          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
