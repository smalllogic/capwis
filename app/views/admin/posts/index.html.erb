<% content_for :admin_title, "Blog 管理" %>

<div class="mb-6 flex justify-between items-center">
  <p class="text-slate-600">管理所有博客文章。</p>
  <%= link_to "写新文章", new_admin_post_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
</div>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <table class="min-w-full divide-y divide-slate-100">
    <thead class="bg-slate-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">标题</th>
        <th class="px-6 py-3 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">状态</th>
        <th class="px-6 py-3 text-left text-xs font-bold text-slate-500 uppercase tracking-wider">发布时间</th>
        <th class="px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase tracking-wider">操作</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @posts.each do |post| %>
        <tr class="hover:bg-slate-50 transition-colors">
          <td class="px-6 py-4">
            <div class="font-semibold text-slate-900 text-sm"><%= post.title %></div>
            <div class="text-xs text-slate-400 mt-1 line-clamp-1"><%= post.summary %></div>
          </td>
          <td class="px-6 py-4">
            <% if post.published? %>
              <span class="px-2 py-1 text-xs font-bold rounded-full bg-green-100 text-green-700">已发布</span>
            <% else %>
              <span class="px-2 py-1 text-xs font-bold rounded-full bg-slate-100 text-slate-500">草稿</span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-sm text-slate-500">
            <%= post.published_at&.strftime("%Y-%m-%d") || "-" %>
          </td>
          <td class="px-6 py-4 text-right space-x-3">
            <%= link_to "编辑", edit_admin_post_path(post), class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
            <%= button_to "删除", admin_post_path(post), method: :delete,
                  data: { confirm: "确定删除这篇文章？" },
                  class: "text-red-500 hover:text-red-700 text-sm font-medium bg-transparent border-0 cursor-pointer" %>
          </td>
        </tr>
      <% end %>
      <% if @posts.empty? %>
        <tr>
          <td colspan="4" class="px-6 py-12 text-center text-slate-400 text-sm">暂无文章</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
