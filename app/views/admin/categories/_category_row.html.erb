<li class="border-l-2 border-slate-100 pl-4 py-2">
  <div class="flex items-center justify-between group">
    <div class="flex items-center space-x-2">
      <span class="inline-flex items-center justify-center w-6 h-6 rounded bg-slate-100 text-[10px] font-mono text-slate-500 mr-1" title="排序位置"><%= category.position || 0 %></span>
      <span class="font-medium text-slate-800"><%= category.name %></span>
      <% if category.featured? %>
        <span class="bg-amber-50 text-amber-600 text-[10px] px-1.5 py-0.5 rounded-full border border-amber-100 font-bold" title="首页推荐，排序: <%= category.featured_position %>">已推荐</span>
      <% end %>
      <% if category.hidden? %>
        <span class="bg-red-50 text-red-600 text-[10px] px-1.5 py-0.5 rounded-full border border-red-100">已隐藏</span>
      <% end %>
      <% if category.skus.exists? %>
        <span class="bg-blue-50 text-blue-600 text-xs px-2 py-0.5 rounded-full border border-blue-100"><%= category.skus.count %> SKUs</span>
      <% end %>
    </div>
    
    <div class="flex items-center space-x-3 opacity-0 group-hover:opacity-100 transition-opacity">
      <% if category.leaf? %>
        <% if category.hidden? %>
          <%= button_to "显示", admin_category_path(category, category: { hidden: false }), method: :patch, class: "text-xs text-green-600 hover:text-green-800" %>
        <% else %>
          <%= button_to "隐藏", admin_category_path(category, category: { hidden: true }), method: :patch, class: "text-xs text-orange-600 hover:text-orange-800" %>
        <% end %>
      <% end %>

      <% unless category.skus.exists? %>
        <%= link_to "添加子分类", new_admin_category_path(parent_id: category.id), class: "text-xs text-blue-600 hover:text-blue-800" %>
      <% end %>
      
      <% if category.children.empty? %>
        <%= link_to "添加 SKU", new_admin_sku_path(category_id: category.id), class: "text-xs text-green-600 hover:text-green-800" %>
      <% end %>
      
      <%= link_to "编辑", edit_admin_category_path(category), class: "text-xs text-slate-500 hover:text-slate-800" %>
      <%= link_to "删除", admin_category_path(category), data: { turbo_method: :delete, turbo_confirm: "确定要删除该分类及其所有子分类吗？" }, class: "text-xs text-red-500 hover:text-red-700" %>
    </div>
  </div>

  <% if category.children.any? %>
    <ul class="mt-2 space-y-2 ml-4">
      <% category.children.each do |child| %>
        <%= render "category_row", category: child %>
      <% end %>
    </ul>
  <% end %>
</li>
