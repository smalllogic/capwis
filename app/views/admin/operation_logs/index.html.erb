<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-slate-800">操作日志</h1>
  <div class="flex items-center gap-4">
    <%= button_to "清理7天前日志", clear_admin_operation_logs_path, 
                  method: :delete, 
                  class: "px-4 py-2 bg-red-50 text-red-600 hover:bg-red-100 rounded-lg text-sm font-medium transition-colors",
                  data: { turbo_confirm: "确定要清理7天前的操作日志吗？" } %>
    <div class="text-sm text-slate-500">
      仅大管理员可见
    </div>
  </div>
</div>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-slate-50 border-b border-slate-200">
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">用户</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">操作</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">资源</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">IP / 时间</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">详情</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        <% if @operation_logs.any? %>
          <% @operation_logs.each do |log| %>
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-6 py-4">
                <div class="text-sm font-medium text-slate-900"><%= log.user&.email %></div>
              </td>
              <td class="px-6 py-4 text-sm">
                <span class="px-2 py-1 bg-slate-100 text-slate-700 rounded text-xs font-mono"><%= log.action %></span>
              </td>
              <td class="px-6 py-4 text-sm text-slate-600">
                <%= log.resource_type %>
              </td>
              <td class="px-6 py-4">
                <div class="text-xs text-slate-600 font-mono"><%= log.ip_address %></div>
                <div class="text-xs text-slate-400 mt-1"><%= log.created_at.strftime("%m-%d %H:%M:%S") %></div>
              </td>
              <td class="px-6 py-4 text-sm font-medium">
                <%= link_to "查看详情", admin_operation_log_path(log), class: "text-primary hover:underline", data: { turbo_frame: "modal" } %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="px-6 py-10 text-center text-slate-500">
              暂无操作日志。
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% if @operation_logs.respond_to?(:total_pages) %>
    <div class="px-6 py-4 border-t border-slate-200">
      <%= paginate @operation_logs %>
    </div>
  <% end %>
</div>
