<% content_for :admin_title, @category.new_record? ? "创建分类" : "编辑分类" %>

<div class="max-w-2xl bg-white p-8 rounded-xl border border-slate-200 shadow-sm">
  <%= form_with(model: [:admin, @category], local: true) do |f| %>
    <% if @category.errors.any? %>
      <div class="mb-6 p-4 bg-red-50 border border-red-100 rounded-lg text-sm text-red-800">
        <ul class="list-disc pl-5">
          <% @category.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-6">
      <%= f.label :name, "英文名称 (English Name)", class: "block text-sm font-medium text-slate-700 mb-2" %>
      <%= f.text_field :name, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
    </div>


    <div class="mb-6">
      <%= f.label :category_kind, "所属频道 (a: performance caps, b: fashion caps, c: custom&work caps)", class: "block text-sm font-medium text-slate-700 mb-2" %>
      <% if @category.parent %>
        <%= f.select :category_kind, [["performance caps (a)", "a"], ["fashion caps (b)", "b"], ["custom&work caps (c)", "c"]], {}, class: "w-full px-4 py-2 border border-slate-300 rounded-lg bg-slate-50 cursor-not-allowed opacity-50", disabled: true %>
        <%= f.hidden_field :category_kind %>
        <p class="mt-1 text-xs text-slate-500">子分类必须与父分类频道一致</p>
      <% else %>
        <%= f.select :category_kind, [["performance caps (a)", "a"], ["fashion caps (b)", "b"], ["custom&work caps (c)", "c"]], { include_blank: "请选择频道" }, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      <% end %>
    </div>

    <% if @category.parent_id || !@category.new_record? %>
      <div class="mb-6">
        <%= f.label :parent_id, "父分类", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.collection_select :parent_id, Category.where.not(id: @category.id), :id, :name, { include_blank: "根分类" }, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>
    <% else %>
      <%= f.hidden_field :parent_id %>
    <% end %>

    <div class="mb-6">
      <%= f.label :position, "排序 (数字越小越靠前)", class: "block text-sm font-medium text-slate-700 mb-2" %>
      <%= f.number_field :position, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500", placeholder: "0" %>
    </div>

    <div class="mb-6 bg-slate-50 p-4 rounded-lg border border-slate-200">
      <div class="flex items-center mb-4">
        <%= f.check_box :featured, class: "w-4 h-4 text-blue-600 border-slate-300 rounded focus:ring-blue-500" %>
        <%= f.label :featured, "推荐到首页 (Featured on Home)", class: "ml-2 block text-sm font-bold text-slate-900" %>
      </div>

      <div class="mb-4">
        <%= f.label :featured_position, "首页推荐排序 (数字越小越靠前)", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.number_field :featured_position, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500", placeholder: "0" %>
      </div>

      <div>
        <%= f.label :image, "分类封面图 (首页显示用)", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.file_field :image, class: "w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" %>
        <% if @category.image.attached? %>
          <div class="mt-2">
            <%= image_tag @category.image.variant(:thumb), class: "w-32 h-32 object-cover rounded-lg border" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex space-x-4">
      <%= f.submit "保存分类", class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-medium transition-colors" %>
      <%= link_to "取消", admin_categories_path, class: "bg-slate-100 hover:bg-slate-200 text-slate-700 px-6 py-2 rounded-lg font-medium transition-colors" %>
    </div>
  <% end %>
</div>
