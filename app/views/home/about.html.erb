<% content_for :title, "#{t('home.about.title')} - Lincaps" %>

<!-- Hero Section: 关于我们 -->
<div class="relative bg-slate-50 py-32 overflow-hidden">
  <div class="absolute inset-0 z-0 opacity-20">
    <!-- 这里可以放背景图 -->
    <div class="absolute inset-0 bg-gradient-to-r from-primary/50 to-transparent"></div>
  </div>
  
  <div class="relative z-10 max-w-screen-xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center px-4 py-2 bg-white border border-slate-200 rounded-full text-primary text-xs font-black tracking-[0.2em] uppercase mb-6 backdrop-blur-sm">
          <span class="w-2 h-2 bg-primary rounded-full mr-3 animate-pulse"></span>
          <%= t('home.about.subtitle') %>
        </div>
        <h1 class="text-5xl md:text-6xl font-black text-slate-900 tracking-tight mb-6">
          <%= t('home.about.hero_title') %>
        </h1>
        <p class="max-w-2xl text-slate-500 text-lg font-medium leading-relaxed">
          <%= t('home.about.hero_desc') %>
        </p>
      </div>
      
      <div class="hidden lg:block relative">
        <div class="aspect-[4/3] rounded-[3rem] overflow-hidden shadow-2xl border border-slate-100">
          <%= image_tag "factory6.jpg", class: "w-full h-full object-cover", alt: "Lincaps Factory" %>
          <div class="absolute inset-0 bg-primary/20 mix-blend-overlay"></div>
        </div>
        <!-- 装饰性元素 -->
        <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-primary/10 rounded-full blur-3xl"></div>
        <div class="absolute -top-6 -left-6 w-32 h-32 bg-secondary/10 rounded-full blur-3xl"></div>
      </div>
    </div>
  </div>
</div>

<!-- 核心板块：历史与实力 -->
<div class="py-24 bg-white overflow-hidden">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      <div class="lg:col-span-5 space-y-8">
        <div>
          <h2 class="text-4xl font-black text-slate-900 mb-8 tracking-tight"><%= t('home.about.heritage_title') %></h2>
          <div class="space-y-6">
            <p class="text-slate-600 text-lg leading-relaxed font-medium">
              <%= t('home.about.heritage_desc_1') %>
            </p>
            <p class="text-slate-600 text-lg leading-relaxed font-medium border-l-4 border-primary pl-6 py-2 bg-slate-50 rounded-r-2xl">
              <%= t('home.about.heritage_desc_2') %>
            </p>
          </div>
        </div>
        
        <div class="grid grid-cols-2 gap-6 pt-4">
          <div class="p-8 bg-slate-50 rounded-[2rem] border border-slate-100 group hover:bg-white hover:shadow-2xl hover:border-primary/20 transition-all duration-500">
            <div class="text-primary font-black text-4xl mb-3">20+</div>
            <p class="text-sm font-bold text-slate-500 uppercase tracking-widest"><%= t('home.about.stats.years') %></p>
          </div>
          <div class="p-8 bg-slate-50 rounded-[2rem] border border-slate-100 group hover:bg-white hover:shadow-2xl hover:border-secondary/20 transition-all duration-500">
            <div class="text-secondary font-black text-4xl mb-3">7+</div>
            <p class="text-sm font-bold text-slate-500 uppercase tracking-widest"><%= t('home.about.stats.subsidiaries') %></p>
          </div>
        </div>
      </div>
      
      <div class="lg:col-span-7 relative group">
        <div class="aspect-[16/10] lg:aspect-[16/9] rounded-[4rem] overflow-hidden shadow-[0_32px_64px_-16px_rgba(0,0,0,0.1)] transition-transform duration-700 group-hover:scale-[1.02]">
          <%= image_tag "global.jpg", class: "w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110", alt: "Lincaps Factory" %>
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
        <!-- 装饰性装饰 -->
        <div class="absolute -bottom-12 -left-12 w-64 h-64 bg-primary/10 rounded-full blur-3xl -z-10 animate-pulse"></div>
        <div class="absolute -top-12 -right-12 w-64 h-64 bg-slate-200/50 rounded-full blur-3xl -z-10"></div>
      </div>
    </div>
  </div>
</div>

<!-- 核心产品线 — Carousel -->
<div class="py-24 bg-slate-50 overflow-hidden">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="text-3xl font-black text-slate-900 tracking-tight"><%= t('home.about.product_lines_title') %></h2>
      <p class="mt-4 text-slate-500 font-medium"></p>
    </div>

    <div
      x-data="{
        current: 0,
        total: <%= @about_carousels.count %>,
        perPage: 3,
        autoTimer: null,
        get maxIndex() { return Math.max(0, this.total - this.perPage); },
        next() { this.current = this.current >= this.maxIndex ? 0 : this.current + 1; },
        prev() { this.current = this.current <= 0 ? this.maxIndex : this.current - 1; },
        startAuto() { this.autoTimer = setInterval(() => this.next(), 4000); },
        stopAuto() { clearInterval(this.autoTimer); }
      }"
      x-init="
        const updatePerPage = () => {
          if (window.innerWidth < 768) perPage = 1;
          else if (window.innerWidth < 1024) perPage = 2;
          else perPage = 3;
        };
        updatePerPage();
        window.addEventListener('resize', () => { updatePerPage(); current = 0; });
        startAuto();
      "
      @mouseenter="stopAuto()"
      @mouseleave="startAuto()"
      class="relative"
    >
      <!-- Carousel track -->
      <div class="overflow-hidden">
        <div
          class="flex transition-transform duration-700 ease-in-out gap-6"
          :style="`transform: translateX(calc(-${current} * (100% / ${perPage} + 24px / ${perPage})))`"
        >
          <% @about_carousels.each do |carousel| %>
            <div class="flex-shrink-0 w-full md:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)]">
              <% card_content = capture do %>
                <div class="relative h-64 bg-slate-50 overflow-hidden">
                  <% if carousel.image.attached? %>
                    <%= image_tag carousel.image.variant(:featured),
                          class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000",
                          alt: carousel.title %>
                  <% else %>
                    <div class="w-full h-full flex items-center justify-center bg-slate-100">
                      <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    </div>
                  <% end %>
                  <% if carousel.description.present? %>
                    <div class="absolute top-4 left-4">
                      <span class="px-3 py-1 bg-primary/90 backdrop-blur-sm text-white text-[10px] font-black uppercase tracking-widest rounded-full shadow-lg">
                        <%= carousel.description %>
                      </span>
                    </div>
                  <% end %>
                </div>
                <div class="p-8 text-center bg-white">
                  <h3 class="text-xl font-black text-slate-900 group-hover:text-primary transition-colors duration-300"><%= carousel.title %></h3>
                  <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em] mt-2 flex items-center justify-center gap-2">
                    <span class="w-4 h-[1px] bg-slate-200"></span>
                    Custom · OEM · ODM
                    <span class="w-4 h-[1px] bg-slate-200"></span>
                  </p>
                </div>
              <% end %>

              <% if carousel.link.present? %>
                <%= link_to carousel.link, class: "block bg-white rounded-[2.5rem] border border-slate-100 shadow-sm hover:shadow-2xl hover:border-primary/20 transition-all duration-500 overflow-hidden group" do %>
                  <%= card_content %>
                <% end %>
              <% else %>
                <div class="block bg-white rounded-[2.5rem] border border-slate-100 shadow-sm overflow-hidden group">
                  <%= card_content %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <% if @about_carousels.count > 1 %>
        <!-- Arrows -->
        <button @click="prev()" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 md:-translate-x-6 w-12 h-12 bg-white border border-slate-100 rounded-full shadow-xl flex items-center justify-center text-slate-400 hover:bg-primary hover:text-white hover:border-primary transition-all duration-300 z-10 group/btn">
          <svg class="w-6 h-6 transform group-hover/btn:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg>
        </button>
        <button @click="next()" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 md:translate-x-6 w-12 h-12 bg-white border border-slate-100 rounded-full shadow-xl flex items-center justify-center text-slate-400 hover:bg-primary hover:text-white hover:border-primary transition-all duration-300 z-10 group/btn">
          <svg class="w-6 h-6 transform group-hover/btn:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
        </button>

        <!-- Dots -->
        <div class="flex justify-center gap-3 mt-12">
          <template x-for="i in Math.max(0, total - perPage + 1)" :key="i">
            <button
              @click="current = i - 1"
              :class="current === i - 1 ? 'bg-primary w-8' : 'bg-slate-200 w-2 hover:bg-slate-300'"
              class="h-2 rounded-full transition-all duration-500"
            ></button>
          </template>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- 制造实力与竞争价值 -->
<div class="py-24 bg-white overflow-hidden">
  <div class="max-w-screen-xl mx-auto px-6">
