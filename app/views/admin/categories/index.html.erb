<% content_for :admin_title, "分类管理" %>

<div class="mb-6 flex justify-between items-center">
  <p class="text-slate-600">管理您的产品分类树。注意：SKU 只能挂在叶子分类上。</p>
  <%= link_to "添加根分类", new_admin_category_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
</div>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <div class="p-6">
    <ul class="space-y-4">
      <% @categories.each do |category| %>
        <%= render "category_row", category: category %>
      <% end %>
    </ul>
  </div>
</div>
