<% content_for :admin_title, "联系消息" %>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-slate-50 border-b border-slate-200">
          <th class="px-6 py-4 text-sm font-semibold text-slate-700">发送者</th>
          <th class="px-6 py-4 text-sm font-semibold text-slate-700">邮箱</th>
          <th class="px-6 py-4 text-sm font-semibold text-slate-700">主题</th>
          <th class="px-6 py-4 text-sm font-semibold text-slate-700">日期</th>
          <th class="px-6 py-4 text-sm font-semibold text-slate-700">操作</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @contact_messages.each do |msg| %>
          <tr class="hover:bg-slate-50 transition-colors <%= 'font-bold bg-blue-50/30' unless msg.read? %>">
            <td class="px-6 py-4 text-sm font-medium text-slate-800 flex items-center">
              <% unless msg.read? %>
                <span class="w-2 h-2 bg-blue-600 rounded-full mr-2"></span>
              <% end %>
              <%= msg.name %>
            </td>
            <td class="px-6 py-4 text-sm text-slate-600"><%= msg.email %></td>
            <td class="px-6 py-4 text-sm text-slate-600 truncate max-w-xs"><%= msg.subject %></td>
            <td class="px-6 py-4 text-sm text-slate-500"><%= msg.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td class="px-6 py-4 text-sm text-slate-600 space-x-3">
              <%= link_to "查看", admin_contact_message_path(msg), class: "text-blue-600 hover:text-blue-800 font-medium" %>
              <%= link_to "删除", admin_contact_message_path(msg), data: { turbo_method: :delete, turbo_confirm: "确定要删除这条消息吗？" }, class: "text-red-500 hover:text-red-700 font-medium" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="mt-8">
  <%= paginate @contact_messages %>
</div>
