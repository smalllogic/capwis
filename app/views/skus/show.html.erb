<% 
  content_for :title, "#{@sku.name} - #{t('home.index.hero_title_2')}"
  content_for :meta_description, "#{@sku.name} - Custom #{@sku.category.localized_name} manufacturer from Qingdao, China. OEM & ODM available. MOQ: #{@sku.moq.presence || '100 pcs'}. Factory-direct pricing from Capwis."
  content_for :meta_keywords, "#{@sku.name}, #{@sku.category.localized_name}, custom hats, OEM hats, hat manufacturer, Qingdao Capwis"
%>
<div class="max-w-screen-xl mx-auto px-4 py-12">
  <!-- 顶部面包屑导航 -->
  <nav class="flex mb-10 items-center space-x-2 text-sm font-bold bg-white/50 backdrop-blur-sm p-3 rounded-xl border border-slate-200/50 w-fit sticky top-20 z-10">
    <%= link_to categories_path, class: "text-slate-400 hover:text-primary transition-colors" do %>
      <%= t('categories.all_products', default: '全部产品') %>
    <% end %>
    <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
    <% @sku.category.ancestors_and_self.each do |cat| %>
      <%= link_to cat.localized_name, categories_path(category_id: cat.id), class: "text-slate-400 hover:text-primary transition-colors" %>
      <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
    <% end %>
    <span class="text-dark truncate max-w-[200px]"><%= @sku.name %></span>
  </nav>

  <!-- 产品主展示区：左右布局 -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 bg-white p-6 lg:p-12 rounded-[2.5rem] border border-slate-100 shadow-2xl shadow-primary/5 overflow-hidden relative">
    <!-- 装饰背景 -->
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary/5 rounded-full blur-3xl opacity-50 -z-0"></div>
    
    <!-- 左侧：媒体展示 (占 5/12) -->
    <div class="lg:col-span-5 relative z-10 space-y-8" x-data="{ activeImage: 0 }">
      <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-2xl overflow-hidden group relative">
        <div class="aspect-square relative overflow-hidden bg-slate-50">
          <% if @sku.images.attached? %>
            <% @sku.sorted_images.each_with_index do |image, index| %>
              <div x-show="activeImage === <%= index %>" 
                   x-cloak
                   x-transition:enter="transition ease-out duration-500"
                   x-transition:enter-start="opacity-0 transform scale-95"
                   x-transition:enter-end="opacity-100 transform scale-100"
                   class="w-full h-full absolute inset-0">
                <% begin %>
                  <%# 使用预定义的 medium 变体，并强制 webp 以减少体积 %>
                  <% variant = image.variant(:medium) %>
                  <% variant_url = url_for(variant) %>
                  <!-- 基础图 -->
                  <%= image_tag variant_url, 
                                class: "w-full h-full object-contain p-4", 
                                style: "background-color: transparent;",
                                loading: index == 0 ? "eager" : "lazy",
                                alt: "#{@sku.name} - #{index + 1}" %>
                <% rescue ArgumentError, ActiveStorage::InvariableError %>
                  <%= image_tag image, class: "w-full h-full object-contain p-4 transition-transform duration-1000 ease-in-out", style: "background-color: transparent;" %>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <div class="w-full h-full flex flex-col items-center justify-center bg-gradient-to-br from-slate-50 to-slate-100">
              <svg class="w-32 h-32 text-slate-200 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              <span class="text-xs font-black text-slate-300 uppercase tracking-widest">Digital Asset Pending</span>
            </div>
          <% end %>
          
          <div class="absolute top-6 left-6 flex flex-col space-y-2">
            <span class="bg-amber-600 text-white px-4 py-1.5 rounded-full text-[10px] font-black tracking-widest uppercase shadow-lg shadow-amber-500/30">
              <%= t('skus.pro_series') %>
            </span>
          </div>
        </div>
      </div>

      <!-- 缩略图列表 -->
      <% if @sku.images.attached? && @sku.images.count > 1 %>
        <div class="flex flex-wrap gap-4 px-2">
          <% @sku.sorted_images.each_with_index do |image, index| %>
            <button @click="activeImage = <%= index %>" 
                    :class="activeImage === <%= index %> ? 'ring-2 ring-primary border-transparent shadow-lg' : 'border-slate-100 hover:border-primary/50'"
                    class="w-20 h-20 rounded-2xl border-2 bg-white overflow-hidden transition-all duration-300 group">
              <% begin %>
                <%= image_tag image.variant(resize_to_limit: [200, 200], saver: { quality: 80 }), class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" %>
              <% rescue ArgumentError, ActiveStorage::InvariableError %>
                <div class="w-full h-full bg-red-50 flex items-center justify-center text-red-400 text-xs">无法预览</div>
              <% end %>
            </button>
          <% end %>
        </div>
      <% end %>
      
    </div>

    <!-- 右侧：产品详情信息 (占 7/12) -->
    <div class="lg:col-span-7 flex flex-col relative z-10 py-4">
      <div class="mb-10">
        <div class="flex items-center space-x-3 mb-6">
          <span class="h-1 w-12 bg-primary rounded-full"></span>
          <span class="text-[10px] font-black text-primary uppercase tracking-[0.3em]">Technical Excellence</span>
        </div>
        
        <h1 class="text-5xl font-black text-dark mb-6 tracking-tight leading-none"><%= @sku.name %></h1>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4 mb-12">
        <% [
          { label: t('skus.item', default: 'Item'), value: @sku.item },
          { label: t('skus.item_no', default: 'Item No.'), value: @sku.item_no },
          { label: t('skus.material', default: 'Material'), value: @sku.material },
          { label: t('skus.specification', default: 'Specification'), value: @sku.specification },
          { label: t('skus.head_circumference', default: 'Head Circumference'), value: @sku.head_circumference },
          { label: t('skus.brim_length', default: 'Brim Length'), value: @sku.brim_length },
          { label: t('skus.closure_type', default: 'Closure Type'), value: @sku.closure_type },
          { label: t('skus.embroidery_print', default: 'Embroidery/Print'), value: @sku.embroidery_print },
          { label: t('skus.color', default: 'Color'), value: @sku.color },
          { label: t('skus.moq', default: 'MOQ'), value: @sku.moq },
          { label: t('skus.sample_time', default: 'Sample Time'), value: @sku.sample_time },
          { label: t('skus.production_lead_time', default: 'Production Lead Time'), value: @sku.production_lead_time },
          { label: t('skus.packing', default: 'Packing'), value: @sku.packing },
          { label: t('skus.carton_size', default: 'Carton Size'), value: @sku.carton_size },
          { label: t('skus.gross_weight', default: 'Gross Weight'), value: @sku.gross_weight }
        ].select { |s| s[:value].present? }.each do |spec| %>
          <div class="group">
            <div class="flex flex-col border-l-2 border-slate-100 pl-4 group-hover:border-primary transition-all duration-300">
              <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-0.5"><%= spec[:label] %></span>
              <span class="text-sm font-black text-dark tracking-tight"><%= spec[:value] %></span>
            </div>
          </div>
        <% end %>
      </div>

      <!-- 操作区域 -->
      <div class="mt-auto space-y-4">
        <div class="grid grid-cols-1 gap-4">
          <%= link_to contact_path, class: "w-full inline-flex justify-center items-center px-10 py-5 bg-primary hover:bg-primary/90 text-white rounded-[1.5rem] font-black text-sm tracking-widest uppercase transition-all duration-300 shadow-2xl shadow-primary/30 group" do %>
            <span><%= t('skus.get_quote') %></span>
            <svg class="w-5 h-5 ml-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          <% end %>
        </div>
        <p class="text-[9px] text-slate-400 text-center sm:text-left font-bold uppercase tracking-tighter">
          <%= t('skus.spec_notice') %>
        </p>
      </div>
    </div>
  </div>

  <!-- 下方：详细特性 -->
  <div class="mt-12 grid grid-cols-1 lg:grid-cols-3 gap-12">
    <div class="lg:col-span-2">
      <div class="bg-white rounded-[2rem] p-10 border border-slate-100 shadow-xl h-full">
        <div class="flex items-center space-x-4 mb-8">
          <h3 class="text-xl font-black text-slate-900 tracking-tight"><%= t('skus.core_features') %></h3>
        </div>
        <div class="bg-slate-50 rounded-2xl p-8 text-slate-600 text-base leading-relaxed font-medium border border-slate-100 prose prose-slate max-w-none">
          <% if @sku.standard_features.present? %>
            <%= @sku.standard_features %>
          <% else %>
            <%= t('skus.default_feature_desc') %>
          <% end %>
        </div>
      </div>
    </div>
    
    <div class="lg:col-span-1">
      <div class="rounded-[2rem] overflow-hidden border border-slate-100 shadow-xl h-full flex flex-col">
        <!-- Avatar header -->
        <div class="bg-gradient-to-br from-primary to-secondary p-8 flex flex-col items-center text-center relative">
          <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 30% 70%, white 1px, transparent 1px); background-size: 18px 18px;"></div>
          <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-white shadow-xl mb-4 relative z-10 bg-white flex items-center justify-center">
            <%= image_tag "hatlogo.png", class: "w-full h-full object-contain p-2", alt: "Capwis" %>
          </div>
          <h3 class="text-white font-black text-lg relative z-10">Marketing Manager</h3>
          <p class="text-white/70 text-xs font-semibold uppercase tracking-widest relative z-10">Capwis · Qingdao</p>
          <div class="inline-flex items-center gap-1.5 mt-3 px-3 py-1 bg-white/20 rounded-full text-white text-xs font-semibold relative z-10">
            <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse"></span>
            Available Now
          </div>
        </div>
        <!-- Contact body -->
        <div class="bg-white flex-1 p-6 flex flex-col gap-4">
          <p class="text-slate-500 text-sm leading-relaxed">Get fast answers on pricing, samples, MOQ, and lead times for this product.</p>
          <a href="https://wa.me/8613165061563" target="_blank"
             class="flex items-center gap-3 p-3 bg-green-50 hover:bg-green-100 rounded-xl transition-colors group">
            <div class="w-9 h-9 bg-green-500 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </div>
            <div>
              <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">WhatsApp</p>
              <p class="text-sm font-semibold text-slate-700">+86 131 6506 1563</p>
            </div>
          </a>
          <a href="mailto:Caroline@lincaps.com"
             class="flex items-center gap-3 p-3 bg-slate-50 hover:bg-slate-100 rounded-xl transition-colors group">
            <div class="w-9 h-9 bg-primary rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <div>
              <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Email</p>
              <p class="text-sm font-semibold text-slate-700">Caroline@lincaps.com</p>
            </div>
          </a>
          <%= link_to contact_path, class: "mt-2 block w-full text-center py-3.5 bg-primary hover:bg-primary/90 text-white rounded-xl font-black text-xs tracking-widest uppercase transition-colors shadow-lg shadow-primary/20" do %>
            Send Enquiry
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- 推荐产品 -->
  <%
    all_in_cat = @sku.category.skus.where(status: 'active').order(position: :desc, created_at: :desc).to_a
    cur_idx    = all_in_cat.index { |s| s.id == @sku.id }
    related    = []
    if cur_idx
      related << all_in_cat[cur_idx - 1] if cur_idx > 0
      related << all_in_cat[cur_idx + 1] if cur_idx + 1 < all_in_cat.length
      related << all_in_cat[cur_idx + 2] if cur_idx + 2 < all_in_cat.length
    end
    related.compact!
  %>
  <% if related.any? %>
    <div class="mt-16">
      <div class="flex items-center gap-4 mb-8">
        <h2 class="text-2xl font-black text-slate-900 tracking-tight">You May Also Like</h2>
        <div class="h-0.5 flex-1 bg-slate-100 rounded-full"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <% related.each do |s| %>
          <%= link_to sku_path(s), class: "group bg-white rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden" do %>
            <div class="aspect-square overflow-hidden bg-slate-50">
              <% if s.images.attached? %>
                <% begin %>
                  <%= image_tag s.sorted_images.first.variant(resize_to_limit: [600, 600], saver: { quality: 80 }),
                                class: "w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-500" %>
                <% rescue ArgumentError, ActiveStorage::InvariableError %>
                  <div class="w-full h-full flex items-center justify-center text-slate-300 text-xs">No Image</div>
                <% end %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center bg-slate-100">
                  <svg class="w-16 h-16 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                </div>
              <% end %>
            </div>
            <div class="p-5">
              <p class="text-[10px] font-bold text-primary uppercase tracking-widest mb-1"><%= s.category.localized_name %></p>
              <h3 class="font-black text-slate-900 text-sm leading-tight group-hover:text-primary transition-colors"><%= s.name %></h3>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
