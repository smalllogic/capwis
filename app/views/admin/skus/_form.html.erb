<% content_for :admin_title, @sku.new_record? ? "创建 SKU" : "编辑 SKU" %>

<div class="max-w-4xl bg-white p-8 rounded-xl border border-slate-200 shadow-sm">
  <%= form_with(model: [:admin, @sku], local: true) do |f| %>
    <% if @sku.errors.any? %>
      <div class="mb-6 p-4 bg-red-50 border border-red-100 rounded-lg text-sm text-red-800">
        <ul class="list-disc pl-5">
          <% @sku.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div class="md:col-span-2">
        <%= f.label :name, "型号名称", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :name, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :category_id, "所属分类 (必须是叶子分类)", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.collection_select :category_id, Category.where.not(id: Category.where.not(parent_id: nil).select(:parent_id)).order(:category_kind, :name), :id, :localized_name, { prompt: "请选择分类" }, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :price, "价格", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.number_field :price, step: 0.01, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :status, "状态", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.select :status, [['上架 (前台显示)', 'active'], ['草稿 (隐藏)', 'draft'], ['归档', 'archived']], { prompt: "请选择 SKU 状态" }, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
        <p class="mt-1 text-xs text-slate-500 italic">选择"草稿"时，该 SKU 不会在前台网站显示。</p>
      </div>

      <div>
        <%= f.label :position, "排序权重 (越大越靠前)", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.number_field :position, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
        <p class="mt-1 text-xs text-slate-500 italic">默认值为 0。前台展示时按此权重倒序排列（数字越大越靠前）。</p>
      </div>

      <div class="md:col-span-2">
        <%= f.label :images, "Product Images", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.file_field :images, multiple: true, accept: "image/*", class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500", 
                        include_hidden: false %>
        <p class="mt-1 text-xs text-slate-500 italic">Uploading new images will append to existing ones. Hold Ctrl/Command to select multiple. JPEG, PNG, GIF, WebP, BMP only.</p>
        
        <% if @sku.images.attached? %>
          <div class="mt-4 grid grid-cols-2 lg:grid-cols-4 gap-4">
            <% @sku.sorted_images.each do |image| %>
              <div class="relative group border border-slate-200 rounded-lg p-2 bg-slate-50">
                <div class="mb-2">
                  <% begin %>
                    <%= image_tag image.variant(:thumb), class: "w-full h-32 object-contain rounded bg-white" %>
                  <% rescue ArgumentError, ActiveStorage::InvariableError => e %>
                    <div class="w-full h-32 bg-red-50 rounded border border-red-200 flex items-center justify-center text-red-400 text-xs" title="File Error: <%= e.message %>">No Preview</div>
                  <% end %>
                </div>
                
                <div class="flex items-center gap-1.5">
                  <span class="text-xs text-slate-500 whitespace-nowrap">Sort:</span>
                  <%= number_field_tag "sku[image_positions][#{image.id}]", image.position, 
                                      class: "flex-grow min-w-[2.5rem] px-2 py-1 text-xs border border-slate-300 rounded focus:ring-blue-500 focus:border-blue-500" %>
                </div>

                <%= link_to delete_image_admin_sku_path(id: @sku.id, image_id: image.id), 
                          data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                          class: "absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-6 h-6 flex items-center justify-center shadow-lg hover:bg-red-600 transition-colors" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                <% end %>
              </div>
            <% end %>
          </div>
          <p class="mt-2 text-xs text-slate-500 italic">Lower values appear first. Click "Save SKU" to apply sort changes.</p>
        <% end %>
      </div>
    </div>

    <!-- Product Details Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div class="md:col-span-2">
        <h3 class="text-lg font-bold text-slate-800 border-b pb-2 mb-4">Product Specifications</h3>
      </div>
      
      <div>
        <%= f.label :item, "Item", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :item, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :item_no, "Item No.", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :item_no, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :product_name, "Product Name", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :product_name, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :material, "Material", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :material, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :specification, "Specification", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :specification, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :head_circumference, "Head Circumference", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :head_circumference, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :brim_length, "Brim Length", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :brim_length, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :closure_type, "Closure Type", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :closure_type, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :embroidery_print, "Embroidery/Print", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :embroidery_print, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :color, "Color", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :color, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :moq, "MOQ", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :moq, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :sample_time, "Sample Time", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :sample_time, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :production_lead_time, "Production Lead Time", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :production_lead_time, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :packing, "Packing", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :packing, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :carton_size, "Carton Size", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :carton_size, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :gross_weight, "Gross Weight", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.text_field :gross_weight, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="md:col-span-2">
        <%= f.label :standard_features, "Detailed Description (Standard Features)", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= f.rich_text_area :standard_features, class: "min-h-[200px] border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>
    </div>

    <div class="flex space-x-4">
      <%= f.submit "保存 SKU", class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-medium transition-colors" %>
      <%= link_to "取消", admin_skus_path, class: "bg-slate-100 hover:bg-slate-200 text-slate-700 px-6 py-2 rounded-lg font-medium transition-colors" %>
    </div>
  <% end %>
</div>
