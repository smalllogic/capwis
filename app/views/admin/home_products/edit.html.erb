<div class="max-w-4xl mx-auto">
  <div class="mb-6">
    <%= link_to admin_home_products_path, class: "text-slate-500 hover:text-primary flex items-center text-sm transition-colors" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      返回列表
    <% end %>
    <h1 class="text-2xl font-bold text-slate-800 mt-2">编辑首页图片</h1>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-8">
    <%= render "form", home_product: @home_product %>
  </div>
</div>
