            </li>
          </ul>
        </div>
      </div>
    </div>
      <hr class="my-6 border-white/10 sm:mx-auto lg:my-8" />
        <div class="sm:flex sm:items-center sm:justify-between">
            <span class="text-sm text-slate-500 sm:text-center">© <%= @site_config.copyright_year.presence || Time.current.year %> <a href="<%= root_path %>" class="hover:text-white transition-colors"><%= @site_config.name.downcase %>™</a>. <%= t('footer.rights_reserved') %>
            </span>
            <div class="flex mt-4 space-x-6 sm:justify-center sm:mt-0">
                <%= link_to t('privacy_policy.title'), privacy_path, class: "text-slate-500 hover:text-white text-sm transition-colors" %>
            </div>
        </div>
    </div>
</footer>
