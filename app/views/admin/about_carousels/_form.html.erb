<%= form_with(model: [:admin, about_carousel], class: "space-y-6") do |f| %>
  <% if about_carousel.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <i class="fas fa-exclamation-circle text-red-400"></i>
        </div>
        <div class="ml-3">
          <p class="text-sm text-red-700">
            <%= pluralize(about_carousel.errors.count, "error") %> prohibited this carousel from being saved:
          </p>
          <ul class="text-sm text-red-700 list-disc ml-5 mt-1">
            <% about_carousel.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-2">
        <%= f.label :title, "标题", class: "block text-sm font-bold text-gray-700" %>
        <%= f.text_field :title, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition" %>
      </div>

      <div class="space-y-2">
        <%= f.label :position, "排序 (数字越小越靠前)", class: "block text-sm font-bold text-gray-700" %>
        <%= f.number_field :position, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition" %>
      </div>
    </div>

    <div class="space-y-2">
      <%= f.label :description, "描述 / 副标题", class: "block text-sm font-bold text-gray-700" %>
      <%= f.text_area :description, rows: 3, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition" %>
    </div>

    <div class="space-y-2">
      <%= f.label :link, "跳转链接 (可选)", class: "block text-sm font-bold text-gray-700" %>
      <%= f.text_field :link, placeholder: "/categories/1", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition" %>
    </div>

    <div class="space-y-2">
      <%= f.label :image, "上传图片 (建议 600x800)", class: "block text-sm font-bold text-gray-700" %>
      <div class="flex items-center space-x-4">
        <% if about_carousel.persisted? && about_carousel.image.attached? %>
          <div class="h-24 w-24 rounded-lg overflow-hidden border border-gray-200">
            <%= image_tag about_carousel.image.variant(:thumb), class: "h-full w-full object-cover" %>
          </div>
        <% end %>
        <%= f.file_field :image, class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20 cursor-pointer" %>
      </div>
    </div>

    <div class="flex items-center space-x-2">
      <%= f.check_box :active, class: "w-5 h-5 text-primary rounded border-gray-300 focus:ring-primary" %>
      <%= f.label :active, "激活 (在 About Us 页面显示)", class: "text-sm font-bold text-gray-700" %>
    </div>
  </div>

  <div class="flex justify-end space-x-4">
    <%= link_to '取消', admin_about_carousels_path, class: "px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition" %>
    <%= f.submit "保存设置", class: "px-6 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition shadow-md cursor-pointer" %>
  </div>
<% end %>
