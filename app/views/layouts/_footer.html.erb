<footer class="bg-dark border-t border-white/5 mt-auto">
    <div class="mx-auto w-full max-w-screen-xl p-4 py-6 lg:py-8">
        <div class="md:flex md:justify-between">
      <div class="mb-6 md:mb-0">
        <a href="<%= root_path %>" class="flex items-center flex-shrink-0">
          <% if @site_config.logo.attached? %>
            <%= image_tag @site_config.logo, class: "h-8 sm:h-10 w-auto max-w-[150px] object-contain", alt: @site_config.name %>
          <% else %>
            <%= image_tag "hatlogo.webp", class: "h-8 sm:h-10 w-auto max-w-[150px] object-contain", alt: "Lincaps Logo" %>
          <% end %>
        </a>
        <p class="mt-2 text-sm text-slate-400"><%= t('footer.company_desc') %></p>
      </div>
      <div class="grid grid-cols-2 gap-8 sm:gap-6 sm:grid-cols-3">
        <div>
          <h2 class="mb-6 text-sm font-semibold text-white uppercase"><%= t('footer.quick_links') %></h2>
          <ul class="text-slate-400 font-medium text-sm space-y-4">
            <li><%= link_to t('navbar.about_us'), about_path, class: "hover:text-primary transition-colors" %></li>
            <li><%= link_to t('navbar.factory'), factory_path, class: "hover:text-primary transition-colors" %></li>
            <li><%= link_to t('navbar.contact_us'), contact_path, class: "hover:text-primary transition-colors" %></li>
          </ul>
        </div>
        <div>
          <h2 class="mb-6 text-sm font-semibold text-white uppercase"><%= t('footer.contact_us') %></h2>
          <ul class="text-slate-400 font-medium text-sm space-y-3">
            <li class="flex items-start">
              <svg class="w-4 h-4 mr-2 mt-0.5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              <span><%= @site_config.address.presence || "Qingdao, Shandong Province, China" %></span>
            </li>
            <li class="flex items-center hover:text-secondary transition-colors cursor-pointer">
              <svg class="w-4 h-4 mr-2 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              <% if @site_config.phone.present? %>
                <a href="tel:<%= @site_config.phone %>" class="hover:underline"><%= @site_config.phone %></a>
              <% else %>
                <a href="https://wa.me/8613165061563" target="_blank" class="hover:underline">+86 13165061563</a>
              <% end %>
            </li>
            <li class="flex items-center hover:text-accent transition-colors cursor-pointer">
              <svg class="w-4 h-4 mr-2 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              <a href="mailto:<%= @site_config.email.presence || "Caroline@lincaps.com" %>" class="hover:underline"><%= @site_config.email.presence || "Caroline@lincaps.com" %></a>
            </li>
          </ul>
        </div>
