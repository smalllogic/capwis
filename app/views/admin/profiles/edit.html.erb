<% content_for :admin_title, "修改密码" %>

<div class="max-w-2xl mx-auto">
  <div class="bg-white shadow rounded-lg p-6">
    <%= form_with(model: @user, url: admin_profile_path, method: :patch, local: true) do |f| %>
      <% if @user.errors.any? %>
        <div class="p-4 mb-6 text-sm text-red-700 bg-red-100 rounded-lg" role="alert">
          <ul>
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-6">
        <div>
          <%= f.label :current_password, "当前密码", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :current_password, class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary focus:border-primary", required: true %>
          <p class="mt-1 text-xs text-gray-500">为了安全起见，修改密码需要验证当前密码</p>
        </div>

        <hr class="border-slate-100">

        <div>
          <%= f.label :password, "新密码", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary focus:border-primary", required: true %>
        </div>

        <div>
          <%= f.label :password_confirmation, "确认新密码", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password_confirmation, class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary focus:border-primary", required: true %>
        </div>
      </div>

      <div class="mt-8 flex justify-end">
        <%= f.submit "确认修改", class: "px-6 py-2 bg-primary text-white font-medium rounded-lg hover:bg-primary/90 transition-colors shadow-sm" %>
      </div>
    <% end %>
  </div>
</div>
