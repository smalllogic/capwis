<% content_for :admin_title, "查看消息" %>

<div class="max-w-4xl bg-white p-8 rounded-xl border border-slate-200 shadow-sm">
  <div class="mb-8 border-b border-slate-100 pb-6 flex justify-between items-start">
    <div>
      <h2 class="text-2xl font-black text-slate-900 mb-2"><%= @contact_message.subject %></h2>
      <div class="flex items-center space-x-4 text-sm text-slate-500">
        <span class="flex items-center">
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          <%= @contact_message.name %>
        </span>
        <span class="flex items-center">
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          <%= @contact_message.email %>
        </span>
        <span class="flex items-center">
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <%= @contact_message.created_at.strftime("%Y-%m-%d %H:%M") %>
        </span>
      </div>
    </div>
    <div class="flex space-x-3">
      <%= link_to "返回列表", admin_contact_messages_path, class: "bg-slate-100 hover:bg-slate-200 text-slate-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
      <%= link_to "删除", admin_contact_message_path(@contact_message), data: { turbo_method: :delete, turbo_confirm: "确定要删除这条消息吗？" }, class: "bg-red-50 text-red-600 hover:bg-red-100 px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
    </div>
  </div>

  <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100">
    <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-4">消息内容</h3>
    <div class="text-slate-700 font-medium leading-relaxed whitespace-pre-line">
      <%= @contact_message.message %>
    </div>
  </div>

  <div class="mt-8 pt-8 border-t border-slate-100">
    <a href="mailto:<%= @contact_message.email %>?subject=Re: <%= @contact_message.subject %>" class="inline-flex items-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-black text-xs tracking-widest uppercase transition-all shadow-lg shadow-blue-500/20">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path></svg>
      邮件回复客户
    </a>
  </div>
</div>
