<div class="mt-8 mb-6 p-6 bg-slate-50 border border-slate-200 rounded-xl">
  <h3 class="text-lg font-bold text-slate-800 mb-4 flex items-center">
    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
    SEO 设置 (TDK)
  </h3>
  
  <div class="mb-4">
    <%= f.label :meta_title, "Meta Title (标题)", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :meta_title, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500", placeholder: "如果不填，将使用默认标题" %>
  </div>

  <div class="mb-4">
    <%= f.label :meta_description, "Meta Description (描述)", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_area :meta_description, rows: 3, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500", placeholder: "如果不填，将使用默认描述" %>
  </div>

  <div class="mb-0">
    <%= f.label :meta_keywords, "Meta Keywords (关键词)", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :meta_keywords, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500", placeholder: "多个关键词用英文逗号隔开" %>
  </div>
</div>