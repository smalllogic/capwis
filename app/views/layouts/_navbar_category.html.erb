<%# app/views/layouts/_navbar_category.html.erb %>
<% 
  group_name = "group/cat-#{depth}"
  hover_class = case depth
                when 1 then "md:group-hover/cat-1:block"
                when 2 then "md:group-hover/cat-2:block"
                when 3 then "md:group-hover/cat-3:block"
                when 4 then "md:group-hover/cat-4:block"
                else "md:group-hover/cat-5:block"
                end
  text_hover_class = case depth
                     when 1 then "group-hover/cat-1:text-primary"
                     when 2 then "group-hover/cat-2:text-primary"
                     when 3 then "group-hover/cat-3:text-primary"
                     when 4 then "group-hover/cat-4:text-primary"
                     else "group-hover/cat-5:text-primary"
                     end
%>
<div class="relative <%= group_name %>">
  <div class="flex items-center justify-between group/item">
    <%= link_to category_path(category), 
        class: "flex-grow px-4 py-3 text-sm text-slate-600 hover:bg-primary hover:text-white transition-all truncate" do %>
      <%= category.localized_name %>
    <% end %>
    
    <% if category.children.visible.any? %>
      <button type="button" 
              data-action="click->navbar#toggleDropdown" 
              class="md:hidden px-4 py-3 text-slate-400 hover:text-primary hover:bg-slate-50 transition-all focus:outline-none">
        <svg class="w-4 h-4 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
      
      <%# Add a visual indicator for desktop that there are children, but not as a separate button %>
      <div class="hidden md:block px-4 py-3 text-slate-400 <%= text_hover_class %> transition-all pointer-events-none">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </div>
    <% end %>
  </div>

  <% if category.children.visible.any? %>
    <div class="hidden <%= hover_class %> md:absolute md:left-full md:top-0 w-64 z-50 dropdown-container pointer-events-auto">
      <div class="bg-white border border-slate-200 rounded-2xl shadow-2xl overflow-visible backdrop-blur-xl bg-opacity-95 py-2 ring-1 ring-slate-900/5 ml-0.5 md:animate-fade-in-right">
        <% category.children.visible.each do |sub_cat| %>
          <%= render 'layouts/navbar_category', category: sub_cat, kind: kind, depth: depth + 1 %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
