<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-slate-800">首页管理 - Our Products</h1>
  <%= link_to new_admin_home_product_path, class: "bg-primary hover:bg-primary/90 text-white px-4 py-2 rounded-lg flex items-center transition-colors" do %>
    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
    </svg>
    添加图片
  <% end %>
</div>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-slate-50 border-b border-slate-200">
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">图片</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">标题</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">行位置</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">排序</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">状态</th>
          <th class="px-6 py-4 text-xs font-semibold text-slate-600 uppercase tracking-wider">操作</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        <% if @home_products.any? %>
          <% @home_products.each do |product| %>
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-6 py-4">
                <% if product.image.attached? %>
                  <%= image_tag product.image.variant(:thumb), class: "w-20 h-20 object-cover rounded-lg border border-slate-200" %>
                <% else %>
                  <div class="w-20 h-20 bg-slate-100 rounded-lg flex items-center justify-center text-slate-400 text-xs italic">无图片</div>
                <% end %>
              </td>
              <td class="px-6 py-4">
                <div class="text-sm font-medium text-slate-900"><%= product.title %></div>
                <div class="text-xs text-slate-500"><%= product.link %></div>
              </td>
              <td class="px-6 py-4">
                <span class="px-2 py-1 rounded text-xs font-medium <%= product.row == 1 ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
                  第 <%= product.row %> 行 (<%= product.row == 1 ? 'Forward' : 'Reverse' %>)
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-slate-600">
                <%= product.position %>
              </td>
              <td class="px-6 py-4">
                <% if product.active %>
                  <span class="px-2 py-1 bg-green-100 text-green-700 rounded text-xs font-medium">显示中</span>
                <% else %>
                  <span class="px-2 py-1 bg-slate-100 text-slate-600 rounded text-xs font-medium">隐藏</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm font-medium space-x-3">
                <%= link_to "编辑", edit_admin_home_product_path(product), class: "text-primary hover:text-primary/80" %>
                <%= button_to "删除", admin_home_product_path(product), method: :delete, data: { confirm: "确定要删除吗？" }, class: "text-red-500 hover:text-red-700 inline-block" %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="6" class="px-6 py-10 text-center text-slate-500">
              暂无首页图片数据，请点击右上方按钮添加。
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
