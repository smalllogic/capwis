<% content_for :admin_title, "系统设置" %>

<div class="max-w-4xl mx-auto">
  <%= form_with(model: @site_config, url: admin_site_config_path, method: :patch, class: "space-y-8") do |f| %>
    <% if @site_config.errors.any? %>
      <div class="p-4 mb-6 text-sm text-red-700 bg-red-100 rounded-lg" role="alert">
        <ul>
          <% @site_config.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
      <h3 class="text-lg font-medium text-slate-800 mb-6 border-b pb-2">基本信息</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= f.label :name, "网站名称", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :name, class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary focus:border-primary" %>
        </div>
        <div>
          <%= f.label :copyright_year, "版权年份", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :copyright_year, class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary focus:border-primary", placeholder: "e.g. 2024" %>
        </div>
        <div>
          <%= f.label :phone, "联系电话", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :phone, class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary focus:border-primary" %>
        </div>
        <div>
          <%= f.label :email, "联系邮箱", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.email_field :email, class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary focus:border-primary" %>
        </div>
        <div class="md:col-span-2">
          <%= f.label :address, "联系地址", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :address, class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary focus:border-primary" %>
        </div>
      </div>
    </div>

    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
      <h3 class="text-lg font-medium text-slate-800 mb-6 border-b pb-2">首页 SEO (TDK)</h3>
      <div class="space-y-6">
        <div>
          <%= f.label :meta_title, "SEO 标题 (Title)", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :meta_title, class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary focus:border-primary" %>
        </div>
        <div>
          <%= f.label :meta_keywords, "关键词 (Keywords)", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :meta_keywords, class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary focus:border-primary", placeholder: "多个关键词用英文逗号隔开" %>
        </div>
        <div>
          <%= f.label :meta_description, "描述 (Description)", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_area :meta_description, rows: 3, class: "w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-primary focus:border-primary" %>
        </div>
      </div>
    </div>

    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
      <h3 class="text-lg font-medium text-slate-800 mb-6 border-b pb-2">外观与统计</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <%= f.label :logo, "网站 Logo", class: "block text-sm font-medium text-slate-700 mb-2" %>
          <% if @site_config.logo.attached? %>
            <div class="mb-3">
              <%= image_tag @site_config.logo, class: "h-12 object-contain bg-slate-100 p-2 rounded" %>
            </div>
          <% end %>
          <%= f.file_field :logo, class: "block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20" %>
        </div>
        <div>
          <%= f.label :favicon, "Favicon (16x16 或 32x32)", class: "block text-sm font-medium text-slate-700 mb-2" %>
          <% if @site_config.favicon.attached? %>
            <div class="mb-3">
              <%= image_tag @site_config.favicon, class: "h-8 w-8 object-contain bg-slate-100 p-1 rounded" %>
            </div>
          <% end %>
          <%= f.file_field :favicon, class: "block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20" %>
        </div>
        <div class="md:col-span-2">
          <%= f.label :statistics_code, "统计代码 (如 Google Analyics, 百度统计)", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_area :statistics_code, rows: 5, class: "w-full px-3 py-2 border border-slate-300 rounded-lg font-mono text-xs focus:ring-primary focus:border-primary", placeholder: "<script>...</script>" %>
        </div>
      </div>
    </div>

    <div class="flex justify-end pt-4">
      <%= f.submit "保存设置", class: "px-6 py-2 bg-primary text-white font-medium rounded-lg hover:bg-primary/90 transition-colors shadow-sm" %>
    </div>
  <% end %>
</div>
