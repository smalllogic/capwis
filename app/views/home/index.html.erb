            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent px-5 pb-6 pt-16">
              <p class="text-white font-black text-xl leading-tight drop-shadow-lg"><%= cap[:name] %></p>
              <p class="text-white/75 text-xs font-bold mt-1 uppercase tracking-widest">Custom · OEM · ODM</p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

