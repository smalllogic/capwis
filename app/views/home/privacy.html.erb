<% content_for :title, "#{t('privacy_policy.title')} - Capwis" %>

<div class="relative bg-slate-50 py-24 overflow-hidden">
  <div class="absolute inset-0 z-0 opacity-10">
    <div class="absolute inset-0 bg-gradient-to-r from-primary/30 to-transparent"></div>
  </div>
  
  <div class="relative z-10 max-w-screen-xl mx-auto px-6">
    <div class="text-center lg:text-left">
      <h1 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight mb-6">
        <%= t('privacy_policy.title') %>
      </h1>
      <p class="max-w-3xl text-slate-500 text-lg font-medium leading-relaxed">
        <%= t('privacy_policy.introduction') %>
      </p>
    </div>
  </div>
</div>

<div class="py-20 bg-white">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="max-w-4xl space-y-12">
      <% ['data_collection', 'usage', 'sharing', 'deletion', 'contact_us'].each do |section| %>
        <section class="group">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-2xl bg-slate-50 flex items-center justify-center text-primary border border-slate-100 group-hover:bg-primary group-hover:text-white transition-all duration-300">
              <span class="text-xl font-black">0<%= ['data_collection', 'usage', 'sharing', 'deletion', 'contact_us'].index(section) + 1 %></span>
            </div>
            <h2 class="text-2xl font-black text-slate-900 tracking-tight"><%= t("privacy_policy.#{section}.title") %></h2>
          </div>
          <div class="bg-slate-50 rounded-[2.5rem] p-8 md:p-10 border border-slate-100 hover:shadow-xl hover:border-primary/10 transition-all duration-500">
            <p class="text-slate-600 text-lg leading-relaxed font-medium">
              <%= t("privacy_policy.#{section}.content") %>
            </p>
          </div>
        </section>
      <% end %>

      <div class="pt-12 border-t border-slate-100">
        <p class="text-slate-400 text-sm font-medium">
          Last updated: <%= Time.current.strftime("%B %d, %Y") %>
        </p>
      </div>
    </div>
  </div>
</div>
