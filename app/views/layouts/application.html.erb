<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Capwis" %></title>
    <meta name="description" content="<%= content_for(:meta_description) || "Capwis is a professional hat manufacturer based in Qingdao, China, with 25 years of manufacturing experience." %>">
    <meta name="keywords" content="<%= content_for(:meta_keywords) || "baseball caps, trucker hats, customized hats, hat manufacturer, Qingdao Capwis" %>">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%= favicon_link_tag "hatlogo.jpg" %>
    <%= favicon_link_tag "hatlogo.jpg", rel: "apple-touch-icon" %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style> [x-cloak] { display: none !important; } </style>
  </head>

  <body class="flex flex-col min-h-screen bg-white">
    <%= render "layouts/navbar" %>
    
    <main class="flex-grow pt-20">
      <% if notice %>
        <div class="max-w-screen-xl mx-auto px-5 mt-4">
          <p class="p-4 text-sm text-blue-800 rounded-lg bg-blue-50 border border-blue-100" role="alert"><%= notice %></p>
        </div>
      <% end %>
      <% if alert %>
        <div class="max-w-screen-xl mx-auto px-5 mt-4">
          <p class="p-4 text-sm text-red-800 rounded-lg bg-red-50 border border-red-100" role="alert"><%= alert %></p>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <!-- Floating Contact Sidebar -->
    <div class="fixed right-5 top-1/2 -translate-y-1/2 z-50 flex flex-col gap-3">
      <% [
        { href: "https://www.facebook.com/share/198Rqf9Khw/?mibextid=wwXIfr", title: "Facebook", bg: "from-blue-500 to-blue-600", shadow: "shadow-blue-500/40", icon: '<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>', stroke: false, target: "_blank" },
        { href: "https://www.instagram.com/caroline585817?igsh=MXhlYjdhYnAycXNqbw%3D%3D&utm_source=qr", title: "Instagram", bg: "from-pink-500 via-red-500 to-yellow-500", shadow: "shadow-pink-500/40", icon: '<path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.58.016 4.85.074 1.17.054 1.802.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.427.359 1.059.415 2.23.058 1.266.074 1.645.074 4.849 0 3.203-.016 3.581-.074 4.849-.054 1.17-.249 1.802-.415 2.227-.217.562-.477.96-.896 1.382-.42.419-.819.679-1.381.896-.427.164-1.059.359-2.23.415-1.266.058-1.645.074-4.849.074-3.203 0-3.581-.016-4.849-.074-1.17-.054-1.802-.249-2.227-.415-.562-.217-.96-.477-1.382-.896-.419-.42-.679-.819-.896-1.381-.164-.427-.359-1.059-.415-2.23C2.176 15.58 2.16 15.203 2.16 12s.016-3.58.074-4.85c.054-1.17.249-1.802.415-2.227.217-.562.477-.96.896-1.382.42-.419.819-.679 1.381-.896.427-.164 1.059-.359 2.23-.415 1.266-.058 1.645-.074 4.849-.074zm0 3.672a6.168 6.168 0 100 12.336 6.168 6.168 0 000-12.336zm0 10.176a4.008 4.008 0 110-8.016 4.008 4.008 0 010 8.016zm6.406-11.845a1.44 1.44 0 11-2.88 0 1.44 1.44 0 012.88 0z"/>', stroke: false, target: "_blank" },
        { href: "https://wa.me/8613165061563", title: "WhatsApp", bg: "from-green-500 to-green-600", shadow: "shadow-green-500/40", icon: '<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>', stroke: false, target: "_blank" },
        { href: "https://www.linkedin.com/in/caroline-lin-510033420", title: "LinkedIn", bg: "from-blue-600 to-blue-700", shadow: "shadow-blue-600/40", icon: '<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>', stroke: false, target: "_blank" },
        { href: "https://www.tiktok.com/@lincaps", title: "TikTok", bg: "from-slate-800 to-slate-900", shadow: "shadow-slate-800/40", icon: '<path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.17 8.17 0 004.78 1.52V6.76a4.85 4.85 0 01-1.01-.07z"/>', stroke: false, target: "_blank" },
        { href: "tel:+8613165061563", title: "+86 131 6506 1563", bg: "from-teal-500 to-teal-600", shadow: "shadow-teal-500/40", icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>', stroke: true, target: "_self" },
        {
          href: "#",
          title: "WeChat",
          bg: "from-green-400 to-green-500",
          shadow: "shadow-green-400/40",
          icon: '<path d="M8.5 4C4.9 4 2 6.4 2 9.3c0 1.7 1 3.2 2.5 4.2L4 16l3-1.5c.5.1 1 .2 1.5.2-.2-.6-.3-1.2-.3-1.8 0-3.2 3-5.8 6.7-5.8.3 0 .6 0 .9.1C14 5.8 11.5 4 8.5 4zm6.5 5.5c-3 0-5.5 1.9-5.5 4.3s2.5 4.3 5.5 4.3c.5 0 1-.1 1.5-.2l2.5 1.2-.5-2c1.2-.8 2-1.9 2-3.3 0-2.4-2.5-4.3-5.5-4.3z"/>',
          stroke: false,
          target: "_self",
          wechat: true
        }
      ].each do |item| %>
        <div class="group flex items-center justify-end">
          <!-- Tooltip label -->
          <span class="fsb-label mr-3 px-3 py-1.5 bg-slate-900 text-white text-xs font-bold rounded-xl whitespace-nowrap shadow-lg opacity-0 translate-x-2 pointer-events-none transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0">
            <%= item[:title] %>
          </span>
          <!-- Icon button -->
          <a
            href="<%= item[:wechat] ? 'javascript:void(0)' : item[:href] %>"
            target="<%= item[:target] %>"
            <% if item[:wechat] %>
            onclick="openWechat()"
            <% end %>
             class="w-12 h-12 rounded-2xl bg-gradient-to-br <%= item[:bg] %> flex items-center justify-center text-white shadow-lg <%= item[:shadow] %> hover:scale-110 hover:rounded-xl transition-all duration-300 flex-shrink-0">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="<%= item[:stroke] ? 'none' : 'currentColor' %>" stroke="<%= item[:stroke] ? 'currentColor' : 'none' %>">
              <%= item[:icon].html_safe %>
            </svg>
          </a>
        </div>
      <% end %>
    </div>

    <!-- WeChat Popup -->
    <div id="wechatModal"
         class="fixed inset-0 bg-black/50 z-[999] hidden items-center justify-center"
         onclick="closeWechat()">

      <div class="bg-white rounded-3xl p-5 shadow-2xl"
           onclick="event.stopPropagation()">

        <img src="<%= asset_path('wx.jpg') %>"
             class="w-72 h-72 object-contain rounded-xl">

        <p class="text-center mt-3 font-bold text-gray-700">
          Scan WeChat QR Code
        </p>

      </div>

    </div>


    <script>
        function openWechat(){
            const box = document.getElementById("wechatModal");
            box.classList.remove("hidden");
            box.classList.add("flex");
        }

        function closeWechat(){
            const box = document.getElementById("wechatModal");
            box.classList.add("hidden");
            box.classList.remove("flex");
        }
    </script>

    <%= render "layouts/footer" %>
    <%= render "shared/privacy_modal" %>
    <%= render "shared/cookie_banner" %>
  </body>
</html>
